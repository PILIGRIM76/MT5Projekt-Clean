        kg_controls_layout = QHBoxLayout()
        self.kg_enabled_checkbox = QCheckBox("Р’РєР»СЋС‡РёС‚СЊ/РћС‚РєР»СЋС‡РёС‚СЊ РІРёР·СѓР°Р»РёР·Р°С†РёСЋ РіСЂР°С„Р°")
        self.kg_enabled_checkbox.setToolTip("Р’РєР»СЋС‡Р°РµС‚/РѕС‚РєР»СЋС‡Р°РµС‚ СЂРµСЃСѓСЂСЃРѕРµРјРєСѓСЋ РѕС‚СЂРёСЃРѕРІРєСѓ РіСЂР°С„Р° Р·РЅР°РЅРёР№ РІ СЂРµР°Р»СЊРЅРѕРј РІСЂРµРјРµРЅРё.")
        # РЈСЃС‚Р°РЅР°РІР»РёРІР°РµРј Р·РЅР°С‡РµРЅРёРµ РёР· РєРѕРЅС„РёРіР°
        self.kg_enabled_checkbox.setChecked(self.trading_system.config.ENABLE_KNOWLEDGE_GRAPH_VISUALIZATION)

