        try:
            from src.core.backtester import Backtester
            self.backtester = Backtester(config=config)
            logger.info("вњ… Backtester РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ")
        except Exception as e:
            logger.error(f"вќЊ РћС€РёР±РєР° РёРЅРёС†РёР°Р»РёР·Р°С†РёРё Backtester: {e}", exc_info=True)
            self.backtester = None

        # РРЅРёС†РёР°Р»РёР·РёСЂСѓРµРј СЃР»РѕРІР°СЂРё
        self.thread_status_labels: Dict[str, QLabel] = {}
        self.scheduler_status_labels: Dict[str, QLabel] = {}

        # РќР°СЃС‚СЂРѕР№РєР° РёРєРѕРЅРєРё
        project_root = os.path.dirname(os.path.abspath(__file__))
        icon_path = os.path.join(project_root, "assets", "icon.ico.ico")
        if os.path.exists(icon_path):
            self.setWindowIcon(QIcon(icon_path))
        else:
            logger.warning(f"Р¤Р°Р№Р» РёРєРѕРЅРєРё РЅРµ РЅР°Р№РґРµРЅ РїРѕ РїСѓС‚Рё: {icon_path}")

        # РќР°СЃС‚СЂРѕР№РєР° РїР°РЅРµР»Рё СѓРІРµРґРѕРјР»РµРЅРёР№
        self.notification_bar = QFrame()
        self.notification_bar.setObjectName("NotificationBar")
        notification_layout = QHBoxLayout()
        self.notification_bar.setLayout(notification_layout)
        self.notification_label = QLabel("")
        notification_layout.addWidget(self.notification_label)
        self.notification_bar.setVisible(False)

        self.notification_timer = QTimer(self)
        self.notification_timer.setSingleShot(True)
        self.notification_timer.timeout.connect(lambda: self.notification_bar.setVisible(False))

        # РќР°СЃС‚СЂРѕР№РєР° GUI Рё СЃРёРіРЅР°Р»РѕРІ
        self.is_graph_ready = False
        self.graph_data_queue = []
        self.scheduler_manager = SchedulerManager()
        self.settings_window = SettingsWindow(self.scheduler_manager, self.config, self)
        self.settings_window.scheduler_status_updated.connect(self.update_thread_status_widget)

        self.setGeometry(100, 100, 1600, 900)

        # --- Р’Р Р•РњР•РќРќР«Р™ Р’РР”Р–Р•Рў Р—РђР“Р РЈР—РљР ---
        self.loading_label = QLabel("Р—Р°РіСЂСѓР·РєР° СЏРґСЂР° Genesis v24.0... РџРѕР¶Р°Р»СѓР№СЃС‚Р°, РїРѕРґРѕР¶РґРёС‚Рµ (AI, DB, NLP).")
        self.loading_widget = QWidget()
        loading_layout = QVBoxLayout(self.loading_widget)
        loading_layout.addWidget(self.loading_label)
        self.setCentralWidget(self.loading_widget)

        # --- РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ GUI (Р»РµРіРєР°СЏ С‡Р°СЃС‚СЊ) ---
        self._init_widgets()  # РЎРѕР·РґР°РЅРёРµ РІСЃРµС… РІРёРґР¶РµС‚РѕРІ, РЅРѕ Р±РµР· РґР°РЅРЅС‹С…
        self.connect_signals()
        self.apply_style("РўРµРјРЅР°СЏ")

        # РќР°СЃС‚СЂРѕР№РєР° С‚Р°Р№РјРµСЂР° СЃС‚Р°С‚СѓСЃР°
        self.status_update_timer = QTimer(self)
        self.status_update_timer.timeout.connect(self.update_scheduler_status_display)
        self.status_update_timer.start(60 * 1000)

        self.update_scheduler_status_display()

        # РўР°Р№РјРµСЂ РѕР±РЅРѕРІР»РµРЅРёСЏ РёРЅС„РѕСЂРјР°С†РёРё РѕР± РѕР±РЅРѕРІР»РµРЅРёСЏС… (РєР°Р¶РґС‹Рµ 30 СЃРµРєСѓРЅРґ)
        self.update_info_timer = QTimer(self)
        self.update_info_timer.timeout.connect(self._update_version_and_monitoring_info)
        self.update_info_timer.start(30 * 1000)

        # РџСЂРµРґРїРѕР»Р°РіР°РµРј, С‡С‚Рѕ kg_enabled_checkbox СЃСѓС‰РµСЃС‚РІСѓРµС‚ РїРѕСЃР»Рµ _init_widgets
        self.kg_enabled_checkbox.setChecked(self.trading_system.config.ENABLE_KNOWLEDGE_GRAPH_VISUALIZATION)
        self.on_kg_toggle()

        # --- РљР РРўРР§Р•РЎРљРћР• РР—РњР•РќР•РќРР•: Р—Р°РїСѓСЃРє С‚СЏР¶РµР»РѕР№ РёРЅРёС†РёР°Р»РёР·Р°С†РёРё РІ QThreadPool ---
        # Р—Р°РїСѓСЃРєР°РµРј СЃСЂР°Р·Сѓ, РЅРµ Р¶РґРµРј 100РјСЃ, РЅРѕ РІ С„РѕРЅРѕРІРѕРј РїРѕС‚РѕРєРµ
        self.start_heavy_initialization()

        # РџРѕРєР°Р·С‹РІР°РµРј СѓРІРµРґРѕРјР»РµРЅРёРµ Рѕ Р·Р°РіСЂСѓР·РєРµ
        # self.show_notification("Р—Р°РїСѓСЃРє С„РѕРЅРѕРІС‹С… СЃРµСЂРІРёСЃРѕРІ\n(РћСЂРєРµСЃС‚СЂР°С‚РѕСЂ, R&D,\n Data Provider)...", 0)

    def _initialize_and_start_blocking(self):
        """
        Р‘Р»РѕРєРёСЂСѓСЋС‰Р°СЏ С„СѓРЅРєС†РёСЏ, РєРѕС‚РѕСЂР°СЏ Р±СѓРґРµС‚ РІС‹РїРѕР»РЅСЏС‚СЊСЃСЏ РІ Worker.
        РћР±СЉРµРґРёРЅСЏРµС‚ РѕР±Рµ С‚СЏР¶РµР»С‹Рµ С„Р°Р·С‹.
        """
        # Р¤Р°Р·Р° 1: РўСЏР¶РµР»Р°СЏ РёРЅРёС†РёР°Р»РёР·Р°С†РёСЏ РєРѕРјРїРѕРЅРµРЅС‚РѕРІ (DB, AI, NLP)
        logger.info("РќР°С‡Р°Р»Рѕ С‚СЏР¶РµР»РѕР№ РёРЅРёС†РёР°Р»РёР·Р°С†РёРё РєРѕРјРїРѕРЅРµРЅС‚РѕРІ (DB, AI, NLP)...")

        # !!! РљР РРўРР§Р•РЎРљРћР• РРЎРџР РђР’Р›Р•РќРР•: РЈР”РђР›РЇР•Рњ РќРР–РќР•Р• РџРћР”Р§Р•Р РљРР’РђРќРР• !!!
        # РџСЂРѕРІРµСЂРєР° РїРµСЂРµРґ РІС‹Р·РѕРІРѕРј
        _method = getattr(
            getattr(self.trading_system, "core_system", None),
            "initialize_heavy_components",
            None,
        )
        if _method:
            _method()

        logger.info("РўСЏР¶РµР»Р°СЏ РёРЅРёС†РёР°Р»РёР·Р°С†РёСЏ Р·Р°РІРµСЂС€РµРЅР°.")

        # Р¤Р°Р·Р° 2: Р—Р°РїСѓСЃРє РїРѕСЃС‚РѕСЏРЅРЅС‹С… С„РѕРЅРѕРІС‹С… СЃРµСЂРІРёСЃРѕРІ (Data Provider, Orchestrator, R&D)
        logger.info("РќР°С‡Р°Р»Рѕ Р·Р°РїСѓСЃРєР° РІСЃРµС… С„РѕРЅРѕРІС‹С… СЃРµСЂРІРёСЃРѕРІ...")
        # Р—Р°РїСѓСЃРєР°РµРј С„РѕРЅРѕРІС‹Рµ СЃРµСЂРІРёСЃС‹ С‡РµСЂРµР· Р°РґР°РїС‚РµСЂ (СЃРёРЅС…СЂРѕРЅРЅРѕ РІ РѕС‚РґРµР»СЊРЅРѕРј РїРѕС‚РѕРєРµ)
        import threading

        def run_background_services():
            try:
                asyncio.run(self.trading_system.start_all_background_services())
            except Exception as e:
                logger.error(f"РћС€РёР±РєР° Р·Р°РїСѓСЃРєР° С„РѕРЅРѕРІС‹С… СЃРµСЂРІРёСЃРѕРІ: {e}", exc_info=True)

        thread = threading.Thread(target=run_background_services, daemon=True, name="BackgroundServices")
        thread.start()
        logger.info("Р’СЃРµ С„РѕРЅРѕРІС‹Рµ СЃРµСЂРІРёСЃС‹ Р·Р°РїСѓС‰РµРЅС‹")
        return True

    @Slot(object)
    def on_heavy_initialization_finished(self, result):
        """
        РЎР»РѕС‚, РІС‹Р·С‹РІР°РµРјС‹Р№ РїРѕСЃР»Рµ СѓСЃРїРµС€РЅРѕРіРѕ Р·Р°РїСѓСЃРєР° РІСЃРµС… С„РѕРЅРѕРІС‹С… СЃРµСЂРІРёСЃРѕРІ.
        Р‘РµР·РѕРїР°СЃРЅРѕ РІС‹РїРѕР»РЅСЏРµС‚СЃСЏ РІ РіР»Р°РІРЅРѕРј РїРѕС‚РѕРєРµ GUI.
        """
        logger.info("РЎРёСЃС‚РµРјР° Genesis v24.0 РїРѕР»РЅРѕСЃС‚СЊСЋ Р°РєС‚РёРІРЅР°. РџРµСЂРµРєР»СЋС‡РµРЅРёРµ РЅР° РѕСЃРЅРѕРІРЅРѕР№ GUI.")

        # 1. GUI СѓР¶Рµ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ РІ __init__, РїСЂРѕСЃС‚Рѕ РїРѕРєР°Р·С‹РІР°РµРј РѕСЃРЅРѕРІРЅРѕР№ РІРёРґР¶РµС‚
        # self._init_widgets()  # РЈР”РђР›Р•РќРћ: РЅРµ РІС‹Р·С‹РІР°С‚СЊ РїРѕРІС‚РѕСЂРЅРѕ!
        # self.connect_signals()  # РЈР”РђР›Р•РќРћ: РЅРµ РїРѕРґРєР»СЋС‡Р°С‚СЊ РїРѕРІС‚РѕСЂРЅРѕ!
        # self.apply_style("РўРµРјРЅР°СЏ")  # РЈР”РђР›Р•РќРћ: СЃС‚РёР»СЊ СѓР¶Рµ РїСЂРёРјРµРЅС‘РЅ

        # 2. Р—Р°РјРµРЅР° РІСЂРµРјРµРЅРЅРѕРіРѕ РІРёРґР¶РµС‚Р° РЅР° РѕСЃРЅРѕРІРЅРѕР№ GUI
        self.setCentralWidget(self.main_central_widget)

        # 3. Р—Р°РїСѓСЃРє С‚Р°Р№РјРµСЂРѕРІ Рё РЅР°С‡Р°Р»СЊРЅС‹С… РѕР±РЅРѕРІР»РµРЅРёР№
        self.status_update_timer = QTimer(self)
        self.status_update_timer.timeout.connect(self.update_scheduler_status_display)
        self.status_update_timer.start(60 * 1000)
        self.update_scheduler_status_display()
        self.kg_enabled_checkbox.setChecked(self.trading_system.config.ENABLE_KNOWLEDGE_GRAPH_VISUALIZATION)
        self.on_kg_toggle()

        # 4. РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ DeFi Widget
        if hasattr(self, "defi_widget") and hasattr(self.trading_system.core_system, "db_manager"):
            logger.info("[DeFi] РџРѕРґРєР»СЋС‡РµРЅРёРµ Рє Р‘Р”...")
            self.defi_widget.set_db_manager(getattr(getattr(self.trading_system, "core_system", None), "db_manager", None))

        if hasattr(self, "control_center_tab"):
            self.control_center_tab.load_initial_settings()

        self.show_notification("РЎРёСЃС‚РµРјР° Genesis v24.0 РїРѕР»РЅРѕСЃС‚СЊСЋ Р°РєС‚РёРІРЅР°.", 5000)

    @Slot(tuple)
    def on_heavy_initialization_error(self, error_info):
        """
        РЎР»РѕС‚ РґР»СЏ РѕР±СЂР°Р±РѕС‚РєРё РѕС€РёР±РѕРє РёРЅРёС†РёР°Р»РёР·Р°С†РёРё.
        """
        exctype, value, traceback_str = error_info
        logger.critical(f"РљСЂРёС‚РёС‡РµСЃРєР°СЏ РѕС€РёР±РєР° РїСЂРё Р·Р°РїСѓСЃРєРµ СЃРµСЂРІРёСЃРѕРІ: {value}\n{traceback_str}")
        # РџРѕРєР°Р·Р°С‚СЊ Р±РµСЃСЃСЂРѕС‡РЅРѕ
        self.show_notification(f"РљР РРўРР§Р•РЎРљРђРЇ РћРЁРР‘РљРђ: {value}", 0)
        self.loading_label.setText(f"РљР РРўРР§Р•РЎРљРђРЇ РћРЁРР‘РљРђ: {value}. РЎРј. Р»РѕРіРё.")
        self.loading_label.setStyleSheet("color: red;")

    def on_left_tab_changed(self, index, tab_widget):
        """РћР±СЂР°Р±РѕС‚С‡РёРє РїРµСЂРµРєР»СЋС‡РµРЅРёСЏ РІРєР»Р°РґРѕРє Р»РµРІРѕР№ РїР°РЅРµР»Рё"""
