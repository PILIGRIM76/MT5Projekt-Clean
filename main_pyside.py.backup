        feedback_layout.addWidget(self.bad_trade_button)
        feedback_layout.addStretch()
        xai_layout.addWidget(self.xai_label)
        xai_layout.addWidget(self.xai_web_view)
        xai_layout.addWidget(feedback_panel)
        right_widget.addTab(xai_tab_widget, "РђРЅР°Р»РёР· РЎРґРµР»РєРё (XAI)")

        # --- Р’РљР›РђР”РљРђ "Р‘Р­РљРўР•РЎРўР•Р " ---
        backtester_tab = QWidget()
        backtester_layout = QVBoxLayout(backtester_tab)
        controls_frame = QFrame()
        controls_layout = QHBoxLayout(controls_frame)
        self.bt_symbol_combo = QComboBox()
        self.bt_test_type_combo = QComboBox()

        self.bt_test_type_combo.addItems(
            ["Event-Driven Backtest", "РЎРёСЃС‚РµРјРЅС‹Р№ Р±СЌРєС‚РµСЃС‚ (Р­РєРѕСЃРёСЃС‚РµРјР°)", "РљР»Р°СЃСЃРёС‡РµСЃРєР°СЏ СЃС‚СЂР°С‚РµРіРёСЏ", "AI РњРѕРґРµР»СЊ"]
        )

        self.bt_strategy_combo = QComboBox()
        self.bt_timeframe_combo = QComboBox()
        self.timeframe_map = {
            "M1": mt5.TIMEFRAME_M1,
            "M5": mt5.TIMEFRAME_M5,
            "M15": mt5.TIMEFRAME_M15,
            "M30": mt5.TIMEFRAME_M30,
            "H1": mt5.TIMEFRAME_H1,
            "H4": mt5.TIMEFRAME_H4,
            "D1": mt5.TIMEFRAME_D1,
            "W1": mt5.TIMEFRAME_W1,
        }
        self.bt_timeframe_combo.addItems(list(self.timeframe_map.keys()))
        self.bt_timeframe_combo.setCurrentText("H1")
        strategy_loader = StrategyLoader(self.trading_system.config)
        strategies = strategy_loader.load_strategies()

        if not strategies:
            self.bt_strategy_combo.addItem("РЎС‚СЂР°С‚РµРіРёРё РЅРµ РЅР°Р№РґРµРЅС‹")
        else:
            for s in strategies:
                self.bt_strategy_combo.addItem(s.__class__.__name__)



if __name__ == "__main__":
    import traceback
    # Форсируем вывод логов в консоль (важно для Windows)
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s | %(levelname)-8s | %(name)s | %(message)s',
        handlers=[
            logging.StreamHandler(sys.stdout),
            logging.FileHandler(Path(__file__).parent / "logs" / "genesis_startup.log", encoding='utf-8', mode='w', delay=True)
        ],
        force=True  # Перезаписываем конфигурацию, если была
    )
    logger = logging.getLogger("genesis")
    logger.info("=" * 80)
    logger.info("🚀 ЗАПУСК GUI APPLICATION")
    logger.info("=" * 80)
    try:
        app = QApplication(sys.argv)
        app.setApplicationName("Genesis Trading System v24.0")
        app.setOrganizationName("NLP-Core-Team")
        # Критично для стабильности Qt на Windows
        app.setAttribute(Qt.ApplicationAttribute.AA_UseSoftwareOpenGL)
        logger.info("✅ QApplication создан")

        # Создаём EventBridge
        from src.gui.event_bridge import GUIEventBridge
        bridge = GUIEventBridge()
        logger.info("✅ GUIEventBridge создан")

# Собираем реальное ядро TradingSystem
        from src.db.database_manager import DatabaseManager
        from src.core.event_bus import get_event_bus

        # 1. DatabaseManager
        db_manager = DatabaseManager(app_config_for_path)
        logger.info("✅ DatabaseManager создан")

        # 2. EventBus
        event_bus = get_event_bus()
        logger.info("✅ EventBus получен")

        # 3. MT5 Connection Manager
        from src.core.mt5_connection_manager import MT5ConnectionManager
        mt5_manager = MT5ConnectionManager(config=app_config_for_path, event_bus=event_bus)
        logger.info("✅ MT5ConnectionManager создан")

        # 4. MLPredictor (если нужен)
        try:
            from src.core.ml_predictor import MLPredictor
            predictor = MLPredictor(config=app_config_for_path, event_bus=event_bus)
            logger.info("✅ MLPredictor создан")
        except Exception as e:
            logger.warning(f"⚠️ MLPredictor не создан: {e}. Используем заглушку.")
            predictor = None

        # 5. Реальное TradingSystem
        trading_system_core = TradingSystem(
            config=app_config_for_path,
            db_manager=db_manager,
            mt5_api=mt5_manager,
            predictor=predictor
        )
        logger.info("✅ TradingSystem (ядро) создан")

        # 6. PySideTradingSystem с ядром
        trading_system_adapter = PySideTradingSystem(
            config=app_config_for_path,
            bridge=bridge,
            trading_system=trading_system_core
        )
        logger.info("✅ PySideTradingSystem (адаптер) создан с ядром")
