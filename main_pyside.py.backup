#
# Р Р•РљРћРњР•РќР”РђР¦РРЇ: Р’С‹РґРµР»РёС‚Рµ 4 СЏРґСЂР° РґР»СЏ СЃРёСЃС‚РµРјС‹, РѕСЃС‚Р°Р»СЊРЅС‹Рµ РѕСЃС‚Р°РІСЊС‚Рµ РћРЎ.
# Р­С‚Рѕ РѕР±РµСЃРїРµС‡РёС‚ Р±Р°Р»Р°РЅСЃ РјРµР¶РґСѓ РїСЂРѕРёР·РІРѕРґРёС‚РµР»СЊРЅРѕСЃС‚СЊСЋ ML Рё РѕС‚Р·С‹РІС‡РёРІРѕСЃС‚СЊСЋ GUI.

cpu_count = 4  # Р’С‹РґРµР»СЏРµРј 4 СЏРґСЂР° РґР»СЏ ML-Р·Р°РґР°С‡
logger.info(f"РСЃРїРѕР»СЊР·СѓРµРј {cpu_count} СЏРґРµСЂ CPU РґР»СЏ РѕР±СѓС‡РµРЅРёСЏ РјРѕРґРµР»РµР№ (РёР· 12 РґРѕСЃС‚СѓРїРЅС‹С…)")

if "OMP_NUM_THREADS" not in os.environ:
    os.environ["OMP_NUM_THREADS"] = str(cpu_count)
if "MKL_NUM_THREADS" not in os.environ:
    os.environ["MKL_NUM_THREADS"] = str(cpu_count)
if "NUMBA_NUM_THREADS" not in os.environ:
    os.environ["NUMBA_NUM_THREADS"] = str(cpu_count)
if "TORCH_NUM_THREADS" not in os.environ:
    os.environ["TORCH_NUM_THREADS"] = str(cpu_count)

# 1. Numba JIT РІРєР»СЋС‡С‘РЅ РґР»СЏ РїСЂРѕРёР·РІРѕРґРёС‚РµР»СЊРЅРѕСЃС‚Рё (РїРѕ СѓРјРѕР»С‡Р°РЅРёСЋ disabled=False)РїСЂРѕРґРѕР»Р¶РёС‚СЊ
# Р•СЃР»Рё РІРѕР·РЅРёРєР°СЋС‚ СЃР±РѕРё, СѓСЃС‚Р°РЅРѕРІРёС‚Рµ РІ "1" РґР»СЏ РѕС‚Р»Р°РґРєРё
os.environ["NUMBA_DISABLE_JIT"] = "0"

# 2. РџР°С‚С‡ РґР»СЏ MKL/OpenMP (РїРѕРјРѕРіР°РµС‚ РїСЂРё РєРѕРЅС„Р»РёРєС‚Р°С… СЃ РїСѓР»Р°РјРё РїРѕС‚РѕРєРѕРІ)
os.environ["KMP_DUPLICATE_LIB_OK"] = "TRUE"

# 3. РџСЂРёРЅСѓРґРёС‚РµР»СЊРЅРѕРµ РѕС‚РєР»СЋС‡РµРЅРёРµ CUDA (РґР»СЏ СѓСЃС‚СЂР°РЅРµРЅРёСЏ РєРѕРЅС„Р»РёРєС‚РѕРІ VRAM/РґСЂР°Р№РІРµСЂРѕРІ)
os.environ["CUDA_VISIBLE_DEVICES"] = ""

# РћСЃС‚Р°РІР»СЏРµРј РўРћР›Р¬РљРћ РѕРґРёРЅ, СЃР°РјС‹Р№ РЅР°РґРµР¶РЅС‹Р№ СЃРїРѕСЃРѕР± СѓСЃС‚Р°РЅРѕРІРёС‚СЊ РїРµСЂРµРјРµРЅРЅСѓСЋ РѕРєСЂСѓР¶РµРЅРёСЏ Р”Рћ РёРјРїРѕСЂС‚РѕРІ
try:
    project_root = Path(__file__).resolve().parent
    settings_path = project_root / "configs" / "settings.json"

    if settings_path.exists():
        with open(settings_path, "r", encoding="utf-8") as f:
            # РџСЂРѕСЃС‚РѕР№ РїР°СЂСЃРёРЅРі JSON Р±РµР· РїРѕР»РЅС‹С… Р·Р°РІРёСЃРёРјРѕСЃС‚РµР№ Pydantic
            settings_data = json.load(f)

        hf_cache_dir_str = settings_data.get("HF_MODELS_CACHE_DIR")

        if hf_cache_dir_str:
            # РџСЂРѕРІРµСЂСЏРµРј, С‡С‚Рѕ РїСѓС‚СЊ РЅРµ РїСѓСЃС‚РѕР№
            try:
                cache_path = Path(hf_cache_dir_str)
                root_disk = cache_path.anchor
                if not Path(root_disk).exists():
                    logger.warning(f"[WARN] РљРѕСЂРЅРµРІРѕР№ РґРёСЃРє '{root_disk}' РґР»СЏ РєСЌС€Р° HF РЅРµ РЅР°Р№РґРµРЅ. РСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ СЃС‚Р°РЅРґР°СЂС‚РЅС‹Р№ РїСѓС‚СЊ.")
                else:
                    cache_path.mkdir(parents=True, exist_ok=True)
                    os.environ["HF_HOME"] = str(cache_path.resolve())
                    # РЎРѕРѕР±С‰РµРЅРёРµ Р±СѓРґРµС‚ РІС‹РІРµРґРµРЅРѕ РїРѕР·Р¶Рµ, С‡РµСЂРµР· СЃРёСЃС‚РµРјСѓ Р»РѕРіРёСЂРѕРІР°РЅРёСЏ
            except Exception as e_mkdir:
                logger.error(
                    f"[ERROR] РќРµ СѓРґР°Р»РѕСЃСЊ СЃРѕР·РґР°С‚СЊ/РёСЃРїРѕР»СЊР·РѕРІР°С‚СЊ РґРёСЂРµРєС‚РѕСЂРёСЋ РґР»СЏ РєСЌС€Р° '{hf_cache_dir_str}'. РџСЂРёС‡РёРЅР°: {e_mkdir}. РСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ СЃС‚Р°РЅРґР°СЂС‚РЅС‹Р№ РїСѓС‚СЊ."
                )
    else:
        logger.warning("[WARN] Р¤Р°Р№Р» settings.json РЅРµ РЅР°Р№РґРµРЅ, РёСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ СЃС‚Р°РЅРґР°СЂС‚РЅС‹Р№ РїСѓС‚СЊ РґР»СЏ РєСЌС€Р° HF.")
except Exception as e:
    logger.error(f"[ERROR] РќРµ СѓРґР°Р»РѕСЃСЊ РїСЂРѕС‡РёС‚Р°С‚СЊ settings.json РґР»СЏ РЅР°СЃС‚СЂРѕР№РєРё HF_HOME: {e}")


