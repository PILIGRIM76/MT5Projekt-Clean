    def show_notification(self, message: str, duration_ms: int = 3000):
        """
        РћС‚РѕР±СЂР°Р¶Р°РµС‚ СѓРІРµРґРѕРјР»РµРЅРёРµ РІ РЅРёР¶РЅРµР№ РїР°РЅРµР»Рё.
        duration_ms = 0 РѕР·РЅР°С‡Р°РµС‚ Р±РµСЃСЃСЂРѕС‡РЅРѕ.
        """
        self.notification_label.setText(message)
        self.notification_bar.setVisible(True)
        if duration_ms > 0:
            self.notification_timer.start(duration_ms)
        else:
            self.notification_timer.stop()

    def _create_vector_db_tab(self):
        widget = QWidget()
        layout = QVBoxLayout(widget)

        # --- Р’РµСЂС…РЅСЏСЏ РїР°РЅРµР»СЊ: РЎС‚Р°С‚РёСЃС‚РёРєР° Рё РЈРїСЂР°РІР»РµРЅРёРµ ---
        top_frame = QFrame()
        top_frame.setFrameShape(QFrame.Shape.StyledPanel)
        top_layout = QHBoxLayout(top_frame)

        # РЎС‚Р°С‚РёСЃС‚РёРєР°
        stats_layout = QVBoxLayout()
        self.vdb_count_label = QLabel("Р”РѕРєСѓРјРµРЅС‚РѕРІ РІ РёРЅРґРµРєСЃРµ: --")
        self.vdb_count_label.setStyleSheet("font-size: 12pt; font-weight: bold; color: #50fa7b;")
        self.vdb_status_label = QLabel("РЎС‚Р°С‚СѓСЃ: РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ...")
        stats_layout.addWidget(self.vdb_count_label)
        stats_layout.addWidget(self.vdb_status_label)

        # РљРЅРѕРїРєРё
        btn_layout = QVBoxLayout()
        self.vdb_refresh_btn = QPushButton("РћР±РЅРѕРІРёС‚СЊ СЃС‚Р°С‚РёСЃС‚РёРєСѓ")
        self.vdb_refresh_btn.clicked.connect(self._refresh_vector_db_stats)
        btn_layout.addWidget(self.vdb_refresh_btn)

        top_layout.addLayout(stats_layout)
        top_layout.addStretch()
        top_layout.addLayout(btn_layout)
        layout.addWidget(top_frame)

        # --- РџР°РЅРµР»СЊ РџРѕРёСЃРєР° ---
        search_group = QGroupBox("РЎРµРјР°РЅС‚РёС‡РµСЃРєРёР№ РџРѕРёСЃРє (RAG)")
        search_layout = QVBoxLayout()
        search_group.setLayout(search_layout)

        input_layout = QHBoxLayout()
        self.vdb_query_edit = QLineEdit()
        self.vdb_query_edit.setPlaceholderText("Р’РІРµРґРёС‚Рµ Р·Р°РїСЂРѕСЃ (РЅР°РїСЂ. 'Inflation impact on Gold' РёР»Рё 'Rate hike')...")
        self.vdb_query_edit.returnPressed.connect(self._run_vector_db_search)

        self.vdb_search_button = QPushButton("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")
        self.vdb_search_button.clicked.connect(self._run_vector_db_search)
        self.vdb_search_button.setStyleSheet("background-color: #bd93f9; color: #282a36; font-weight: bold;")

        input_layout.addWidget(self.vdb_query_edit)
        input_layout.addWidget(self.vdb_search_button)
        search_layout.addLayout(input_layout)
        layout.addWidget(search_group)

        # --- РўР°Р±Р»РёС†Р° Р РµР·СѓР»СЊС‚Р°С‚РѕРІ ---
        self.vdb_results_table = QTableWidget()
        self.vdb_results_table.setColumnCount(4)
        self.vdb_results_table.setHorizontalHeaderLabels(["РЎС…РѕРґСЃС‚РІРѕ", "РСЃС‚РѕС‡РЅРёРє", "Р”Р°С‚Р°", "Р¤СЂР°РіРјРµРЅС‚ С‚РµРєСЃС‚Р°"])
        self.vdb_results_table.horizontalHeader().setSectionResizeMode(3, QHeaderView.ResizeMode.Stretch)
        self.vdb_results_table.horizontalHeader().setSectionResizeMode(0, QHeaderView.ResizeMode.ResizeToContents)
        self.vdb_results_table.setAlternatingRowColors(True)
        self.vdb_results_table.setSelectionBehavior(QTableWidget.SelectionBehavior.SelectRows)
        layout.addWidget(self.vdb_results_table)

        # РџРѕРґРєР»СЋС‡РµРЅРёРµ СЃРёРіРЅР°Р»РѕРІ (РµСЃР»Рё bridge СѓР¶Рµ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ)
        if hasattr(self, 'bridge') and self.bridge is not None:
            self.bridge.vector_db_search_results.connect(self._display_vector_db_results)
        else:
            logger.warning("[VectorDB-GUI] Bridge РЅРµ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ, РїРѕРґРєР»СЋС‡РµРЅРёРµ СЃРёРіРЅР°Р»РѕРІ РѕС‚Р»РѕР¶РµРЅРѕ")

        # РђРІС‚Рѕ-РѕР±РЅРѕРІР»РµРЅРёРµ СЃС‚Р°С‚РёСЃС‚РёРєРё С‡РµСЂРµР· 2 СЃРµРєСѓРЅРґС‹ РїРѕСЃР»Рµ СЃС‚Р°СЂС‚Р°
        QTimer.singleShot(2000, self._refresh_vector_db_stats)

        return widget

    def _refresh_vector_db_stats(self):
        """РЎРёРЅС…СЂРѕРЅРЅС‹Р№ С‚СЂРёРіРіРµСЂ (РІС‹Р·С‹РІР°РµС‚СЃСЏ QTimer, РЅРµ Р±Р»РѕРєРёСЂСѓРµС‚ GUI)"""
        import threading

        def fetch_and_apply():
            """РђСЃРёРЅС…СЂРѕРЅРЅРѕРµ РїРѕР»СѓС‡РµРЅРёРµ РґР°РЅРЅС‹С… РёР· VectorDB"""
            import asyncio

            try:
                if hasattr(self.trading_system, "get_vector_db_stats"):
                    loop = asyncio.new_event_loop()
                    stats = loop.run_until_complete(self.trading_system.get_vector_db_stats())
                    loop.close()

                    if isinstance(stats, dict):
                        count = stats.get("count", 0)
                        ready = stats.get("is_ready", False)
                        has_embedding = stats.get("has_embedding_model", False)
                        reason = stats.get("reason", "")

                        # Р‘РµР·РѕРїР°СЃРЅРѕРµ РѕР±РЅРѕРІР»РµРЅРёРµ UI РІ РіР»Р°РІРЅРѕРј РїРѕС‚РѕРєРµ С‡РµСЂРµР· QTimer
                        from PySide6.QtCore import QTimer

                        QTimer.singleShot(0, lambda: self._apply_vdb_stats(count, ready, has_embedding, reason))
                    else:
                        logger.warning(f"[VectorDB-GUI] РќРµРѕР¶РёРґР°РЅРЅС‹Р№ С„РѕСЂРјР°С‚ РѕС‚РІРµС‚Р°: {type(stats)}")
                else:
                    logger.warning("[VectorDB-GUI] РњРµС‚РѕРґ get_vector_db_stats РЅРµ РЅР°Р№РґРµРЅ")
            except Exception as e:
                logger.error(f"[VectorDB-GUI] РћС€РёР±РєР° Р·Р°РіСЂСѓР·РєРё СЃС‚Р°С‚РёСЃС‚РёРєРё: {e}", exc_info=True)

        threading.Thread(target=fetch_and_apply, daemon=True).start()

    def _apply_vdb_stats(self, count: int, is_ready: bool, has_embedding: bool, reason: str):
        """РџСЂРёРјРµРЅРµРЅРёРµ РґР°РЅРЅС‹С… Рє РІРёРґР¶РµС‚Р°Рј (РІС‹РїРѕР»РЅСЏРµС‚СЃСЏ СЃС‚СЂРѕРіРѕ РІ Qt MainThread)"""
        try:
            if hasattr(self, "vdb_count_label"):
                self.vdb_count_label.setText(f"Р”РѕРєСѓРјРµРЅС‚РѕРІ РІ РёРЅРґРµРєСЃРµ: {count}")

            if is_ready:
                status_text = "РђРљРўРР’РќРђ"
                color = "#50fa7b"
            elif reason:
                status_text = f"РћРЁРР‘РљРђ: {reason}"
                color = "#ff5555"
            elif not has_embedding:
                status_text = "РќР•Рў EMBEDDING РњРћР”Р•Р›Р"
                color = "#ff5555"
            else:
                status_text = "РќР• Р“РћРўРћР’Рђ"
                color = "#ff5555"

            if hasattr(self, "vdb_status_label"):
                self.vdb_status_label.setText(f"РЎС‚Р°С‚СѓСЃ: {status_text}")
                self.vdb_status_label.setStyleSheet(f"color: {color}; font-weight: bold;")

            logger.info(
                f"[VectorDB-GUI] РЎС‚Р°С‚РёСЃС‚РёРєР° РѕР±РЅРѕРІР»РµРЅР°: РґРѕРєСѓРјРµРЅС‚РѕРІ={count}, РіРѕС‚РѕРІ={is_ready}, embedding={has_embedding}"
            )
        except Exception as e:
            logger.error(f"[VectorDB-GUI] РћС€РёР±РєР° РѕР±РЅРѕРІР»РµРЅРёСЏ UI: {e}")

    def _on_vector_db_search(self):
        query = self.vdb_query_edit.text().strip()
        if not query:
            return

        self.vdb_search_button.setEnabled(False)
        self.vdb_search_button.setText("РџРѕРёСЃРє...")
        self.vdb_results_table.setRowCount(0)

        # Р—Р°РїСѓСЃРєР°РµРј РїРѕРёСЃРє РІ РѕС‚РґРµР»СЊРЅРѕРј РїРѕС‚РѕРєРµ С‡РµСЂРµР· TradingSystem
        threading.Thread(
            target=getattr(getattr(self.trading_system, "core_system", None), "search_vector_db", None),
            args=(query,),
            daemon=True,
        ).start()

    # --- РЎР›РћРў Р”Р›РЇ РћР‘РќРћР’Р›Р•РќРРЇ РўРђР‘Р›РР¦Р« Р Р•Р—РЈР›Р¬РўРђРўРћР’ ---
    @Slot(list)
    def update_vector_db_table(self, results: list):
        self.vdb_search_button.setEnabled(True)
        self.vdb_search_button.setText("РќР°Р№С‚Рё РІ Р‘Р°Р·Рµ Р—РЅР°РЅРёР№")

        if not results:
            QMessageBox.information(self, "РџРѕРёСЃРє", "РќРёС‡РµРіРѕ РЅРµ РЅР°Р№РґРµРЅРѕ.")
            return

        if "error" in results[0]:
            QMessageBox.warning(self, "РћС€РёР±РєР°", results[0]["error"])
            return

        self.vdb_results_table.setRowCount(len(results))
        for i, item in enumerate(results):
            # РЎС…РѕРґСЃС‚РІРѕ (Distance)
            dist_item = QTableWidgetItem(f"{float(item.get('distance', 0)):.4f}")
            dist_item.setTextAlignment(Qt.AlignmentFlag.AlignCenter)

            # РСЃС‚РѕС‡РЅРёРє
            source_item = QTableWidgetItem(str(item.get("source", "N/A")))

            # Р”Р°С‚Р°
            date_str = item.get("timestamp", "N/A")
            if "T" in date_str:
                date_str = date_str.split("T")[0]
            date_item = QTableWidgetItem(date_str)

            # РўРµРєСЃС‚
            text_item = QTableWidgetItem(str(item.get("snippet", "")))
            # РџРѕР»РЅС‹Р№ С‚РµРєСЃС‚ РІ РїРѕРґСЃРєР°Р·РєРµ
            text_item.setToolTip(str(item.get("full_text", "")))

            self.vdb_results_table.setItem(i, 0, dist_item)
            self.vdb_results_table.setItem(i, 1, source_item)
            self.vdb_results_table.setItem(i, 2, date_item)
            self.vdb_results_table.setItem(i, 3, text_item)

    def _run_vector_db_search(self):
        query = self.vdb_query_edit.text().strip()
        if not query:
            QMessageBox.warning(self, "Р’РЅРёРјР°РЅРёРµ", "Р’РІРµРґРёС‚Рµ РїРѕРёСЃРєРѕРІС‹Р№ Р·Р°РїСЂРѕСЃ.")
            # РЈР±РµРґРёРјСЃСЏ, С‡С‚Рѕ РєРЅРѕРїРєР° РІ РЅРѕСЂРјР°Р»СЊРЅРѕРј СЃРѕСЃС‚РѕСЏРЅРёРё
            self.vdb_search_button.setEnabled(True)
            self.vdb_search_button.setText("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")
            return

        logger.info(f"[VectorDB-GUI] Р—Р°РїСѓСЃРє РїРѕРёСЃРєР°: '{query}'")

        # РџСЂРѕРІРµСЂСЏРµРј, С‡С‚Рѕ СЃРёСЃС‚РµРјР° РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅР°
        if not hasattr(self.trading_system, "search_vector_db"):
            logger.error("[VectorDB-GUI] РњРµС‚РѕРґ search_vector_db РЅРµ РЅР°Р№РґРµРЅ РІ trading_system")
            QMessageBox.critical(self, "РћС€РёР±РєР°", "РЎРёСЃС‚РµРјР° VectorDB РЅРµ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅР°")
            return

        if not hasattr(self.trading_system, "core_system"):
            logger.error("[VectorDB-GUI] core_system РЅРµ РЅР°Р№РґРµРЅ РІ trading_system")
            QMessageBox.critical(self, "РћС€РёР±РєР°", "РўРѕСЂРіРѕРІР°СЏ СЃРёСЃС‚РµРјР° РЅРµ Р·Р°РїСѓС‰РµРЅР°. РќР°Р¶РјРёС‚Рµ 'Р—Р°РїСѓСЃС‚РёС‚СЊ С‚РѕСЂРіРѕРІР»СЋ'")
            return

        self.vdb_search_button.setEnabled(False)
        self.vdb_search_button.setText("РџРѕРёСЃРє...")
        self.vdb_results_table.setRowCount(0)

        # --- РРЎРџР РђР’Р›Р•РќРР•: Р’С‹Р·С‹РІР°РµРј РїСЂРѕРєСЃРё-РјРµС‚РѕРґ, РєРѕС‚РѕСЂС‹Р№ РёСЃРїРѕР»СЊР·СѓРµС‚ QThreadPool ---
        try:
            logger.info(f"[VectorDB-GUI] Р’С‹Р·РѕРІ trading_system.search_vector_db('{query}')")
            self.trading_system.search_vector_db(query)
            logger.info(f"[VectorDB-GUI] РњРµС‚РѕРґ search_vector_db РІС‹Р·РІР°РЅ СѓСЃРїРµС€РЅРѕ")
        except Exception as e:
            logger.error(f"[VectorDB-GUI] РћС€РёР±РєР° РїСЂРё РІС‹Р·РѕРІРµ search_vector_db: {e}", exc_info=True)
            self.vdb_search_button.setEnabled(True)
            self.vdb_search_button.setText("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")
            QMessageBox.critical(self, "РћС€РёР±РєР°", f"РћС€РёР±РєР° РїСЂРё Р·Р°РїСѓСЃРєРµ РїРѕРёСЃРєР°: {e}")
            return

        # РўР°Р№РјР°СѓС‚ РЅР° СЃР»СѓС‡Р°Р№, РµСЃР»Рё СЂРµР·СѓР»СЊС‚Р°С‚С‹ РЅРµ РїСЂРёРґСѓС‚ (Р·Р°С‰РёС‚Р° РѕС‚ Р·Р°РІРёСЃР°РЅРёСЏ РєРЅРѕРїРєРё)
        # 10 СЃРµРєСѓРЅРґ С‚Р°Р№РјР°СѓС‚
        QTimer.singleShot(10000, self._restore_search_button)

    def _restore_search_button(self):
        """Р’РѕСЃСЃС‚Р°РЅР°РІР»РёРІР°РµС‚ РєРЅРѕРїРєСѓ РїРѕРёСЃРєР° (Р·Р°С‰РёС‚Р° РѕС‚ Р·Р°РІРёСЃР°РЅРёСЏ)"""
        if not self.vdb_search_button.isEnabled():
            logger.warning("[VectorDB-GUI] РўР°Р№РјР°СѓС‚ РїРѕРёСЃРєР° - РІРѕСЃСЃС‚Р°РЅРѕРІР»РµРЅРёРµ РєРЅРѕРїРєРё")
            self.vdb_search_button.setEnabled(True)
            self.vdb_search_button.setText("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")

    @Slot(list)
    def _display_vector_db_results(self, results: list):
        """РћС‚РѕР±СЂР°Р¶Р°РµС‚ СЂРµР·СѓР»СЊС‚Р°С‚С‹ РїРѕРёСЃРєР° РІ VectorDB"""
        try:
            logger.info(
                f"[VectorDB-GUI] ===== _display_vector_db_results Р’Р«Р—Р’РђРќ СЃ {len(results) if results else 0} СЂРµР·СѓР»СЊС‚Р°С‚Р°РјРё ====="
            )

            # Р’СЃРµРіРґР° РІРѕСЃСЃС‚Р°РЅР°РІР»РёРІР°РµРј РєРЅРѕРїРєСѓ РІ РЅР°С‡Р°Р»Рµ
            self.vdb_search_button.setEnabled(True)
            self.vdb_search_button.setText("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")
            logger.info(f"[VectorDB-GUI] РљРЅРѕРїРєР° РІРѕСЃСЃС‚Р°РЅРѕРІР»РµРЅР°")

            if not results:
                logger.warning("[VectorDB-GUI] Р РµР·СѓР»СЊС‚Р°С‚С‹ РїСѓСЃС‚С‹Рµ")
                QMessageBox.information(self, "Р РµР·СѓР»СЊС‚Р°С‚", "Р РµР·СѓР»СЊС‚Р°С‚С‹ РЅРµ РїРѕР»СѓС‡РµРЅС‹.")
                return

            if "error" in results[0]:
                logger.error(f"[VectorDB-GUI] РџРѕР»СѓС‡РµРЅР° РѕС€РёР±РєР°: {results[0]['error']}")
                QMessageBox.critical(self, "РћС€РёР±РєР° РїРѕРёСЃРєР°", results[0]["error"])
                return

            if "message" in results[0]:
                logger.info(f"[VectorDB-GUI] РџРѕР»СѓС‡РµРЅРѕ СЃРѕРѕР±С‰РµРЅРёРµ: {results[0]['message']}")
                QMessageBox.information(self, "Р РµР·СѓР»СЊС‚Р°С‚", results[0]["message"])
                return

            logger.info(f"[VectorDB-GUI] Р—Р°РїРѕР»РЅРµРЅРёРµ С‚Р°Р±Р»РёС†С‹ {len(results)} СЂРµР·СѓР»СЊС‚Р°С‚Р°РјРё")
            self.vdb_results_table.setRowCount(len(results))
            for i, res in enumerate(results):
                # Р›РѕРіРёСЂСѓРµРј РїРµСЂРІС‹Р№ СЂРµР·СѓР»СЊС‚Р°С‚ РґР»СЏ РѕС‚Р»Р°РґРєРё
                if i == 0:
                    logger.info(f"[VectorDB-GUI] РџСЂРёРјРµСЂ СЂРµР·СѓР»СЊС‚Р°С‚Р°: {res}")

                # РЎС…РѕРґСЃС‚РІРѕ (С‡РµРј РјРµРЅСЊС€Рµ РґРёСЃС‚Р°РЅС†РёСЏ, С‚РµРј Р»СѓС‡С€Рµ, РґР»СЏ L2)
                # Р”Р»СЏ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ РјРѕР¶РЅРѕ РёРЅРІРµСЂС‚РёСЂРѕРІР°С‚СЊ РёР»Рё РїСЂРѕСЃС‚Рѕ РїРѕРєР°Р·Р°С‚СЊ РґРёСЃС‚Р°РЅС†РёСЋ
                dist_val = float(res.get("distance", 0))
                similarity_str = f"{dist_val:.4f}"

                self.vdb_results_table.setItem(i, 0, QTableWidgetItem(similarity_str))
                self.vdb_results_table.setItem(i, 1, QTableWidgetItem(res.get("source", "N/A")))

                ts = res.get("timestamp", "N/A")
                if "T" in ts:
                    ts = ts.split("T")[0]
                self.vdb_results_table.setItem(i, 2, QTableWidgetItem(ts))

                snippet = res.get("snippet", "РќРµС‚ С‚РµРєСЃС‚Р°")
                item_text = QTableWidgetItem(snippet)
                # РџРѕР»РЅС‹Р№ С‚РµРєСЃС‚ РІ РїРѕРґСЃРєР°Р·РєРµ
                item_text.setToolTip(res.get("full_text", snippet))
                self.vdb_results_table.setItem(i, 3, item_text)

            logger.info(f"[VectorDB-GUI] РўР°Р±Р»РёС†Р° СѓСЃРїРµС€РЅРѕ Р·Р°РїРѕР»РЅРµРЅР°")

        except Exception as e:
            logger.error(f"[VectorDB-GUI] РћС€РёР±РєР° РїСЂРё РѕС‚РѕР±СЂР°Р¶РµРЅРёРё СЂРµР·СѓР»СЊС‚Р°С‚РѕРІ: {e}", exc_info=True)
            # РЈР±РµРґРёРјСЃСЏ, С‡С‚Рѕ РєРЅРѕРїРєР° РІРѕСЃСЃС‚Р°РЅРѕРІР»РµРЅР° РґР°Р¶Рµ РїСЂРё РѕС€РёР±РєРµ
            self.vdb_search_button.setEnabled(True)
            self.vdb_search_button.setText("РќР°Р№С‚Рё РїРѕС…РѕР¶РёРµ РЅРѕРІРѕСЃС‚Рё")
            QMessageBox.critical(self, "РћС€РёР±РєР°", f"РћС€РёР±РєР° РїСЂРё РѕС‚РѕР±СЂР°Р¶РµРЅРёРё СЂРµР·СѓР»СЊС‚Р°С‚РѕРІ: {e}")

    def update_scheduler_status_display(self):
        """РћР±РЅРѕРІР»СЏРµС‚ РёРЅС„РѕСЂРјР°С†РёСЋ Рѕ Р·Р°РїР»Р°РЅРёСЂРѕРІР°РЅРЅС‹С… Рё РІС‹РїРѕР»РЅРµРЅРЅС‹С… Р·Р°РґР°С‡Р°С… РІ GUI."""
        try:
            project_root = Path(os.path.dirname(os.path.abspath(__file__)))

            # --- РћР±СЂР°Р±РѕС‚РєР° РґР»СЏ РћР±СЃР»СѓР¶РёРІР°РЅРёСЏ ---
            maint_label = self.scheduler_status_labels.get("Maintenance")
            if maint_label:
                maint_time_str = self.scheduler_manager.get_task_trigger_time("GenesisMaintenance")
                maint_status_file = project_root / "database" / "maintenance_status.json"

                last_run_str = ""
                if maint_status_file.exists():
                    try:
                        with open(maint_status_file, "r") as f:
                            data = json.load(f)
                            last_run_utc = datetime.fromisoformat(data["last_run_utc"])
                            last_run_local = last_run_utc.astimezone()
                            last_run_str = f" (Р’С‹РїРѕР»РЅРµРЅРѕ: {last_run_local.strftime('%d.%m %H:%M')})"
                    except Exception as e:
                        logger.error(f"РћС€РёР±РєР° С‡С‚РµРЅРёСЏ С„Р°Р№Р»Р° СЃС‚Р°С‚СѓСЃР° РѕР±СЃР»СѓР¶РёРІР°РЅРёСЏ: {e}")

                display_text = f"Р•Р¶РµРґРЅРµРІРЅРѕ РІ {maint_time_str}" if maint_time_str else "РќРµ РЅР°СЃС‚СЂРѕРµРЅРѕ"
                maint_label.setText(display_text + last_run_str)
                maint_label.setStyleSheet("color: #8be9fd;" if maint_time_str else "color: #f1fa8c;")

            # --- РћР±СЂР°Р±РѕС‚РєР° РґР»СЏ РћРїС‚РёРјРёР·Р°С†РёРё ---
            opt_label = self.scheduler_status_labels.get("Optimization")
            if opt_label:
                opt_time_str = self.scheduler_manager.get_task_trigger_time("GenesisWeeklyOptimization")
                opt_status_file = project_root / "database" / "optimization_status.json"

                last_run_str = ""
                if opt_status_file.exists():
                    try:
                        with open(opt_status_file, "r") as f:
                            data = json.load(f)
                            last_run_utc = datetime.fromisoformat(data["last_run_utc"])
                            last_run_local = last_run_utc.astimezone()
                            last_run_str = f" (Р’С‹РїРѕР»РЅРµРЅРѕ: {last_run_local.strftime('%d.%m %H:%M')})"
                    except Exception as e:
                        logger.error(f"РћС€РёР±РєР° С‡С‚РµРЅРёСЏ С„Р°Р№Р»Р° СЃС‚Р°С‚СѓСЃР° РѕРїС‚РёРјРёР·Р°С†РёРё: {e}")

                display_text = f"Р•Р¶РµРЅРµРґРµР»СЊРЅРѕ (РЎР±) РІ {opt_time_str}" if opt_time_str else "РќРµ РЅР°СЃС‚СЂРѕРµРЅРѕ"
                opt_label.setText(display_text + last_run_str)
                opt_label.setStyleSheet("color: #8be9fd;" if opt_time_str else "color: #f1fa8c;")

        except Exception as e:
            logger.error(f"РљСЂРёС‚РёС‡РµСЃРєР°СЏ РѕС€РёР±РєР° РІ update_scheduler_status_display: {e}", exc_info=True)

    def update_thread_status_widget(self, scheduler_summary: dict):
        """
        РЎР»РѕС‚ РґР»СЏ РїСЂРёРµРјР° Рё РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ СЃС‚Р°С‚СѓСЃР° РїР»Р°РЅРёСЂРѕРІС‰РёРєР°.
        """
        # РџСЂРёРјРµСЂ: РћР±РЅРѕРІР»РµРЅРёРµ QLabel РёР»Рё QTableWidget СЂСЏРґРѕРј СЃРѕ СЃС‚Р°С‚СѓСЃРѕРј РїРѕС‚РѕРєРѕРІ

        status_text = "РџР»Р°РЅРёСЂРѕРІС‰РёРє:\n"
        for task_name, status in scheduler_summary.items():
            # РЈР±РёСЂР°РµРј РїСЂРµС„РёРєСЃ "Genesis" РґР»СЏ РєСЂР°С‚РєРѕСЃС‚Рё
            display_name = task_name.replace("Genesis", "")
            status_text += f"  {display_name}: {status}\n"

    def _handle_long_task_status(self, task_id: str, message: str, is_finished: bool):
        """РџРѕРєР°Р·С‹РІР°РµС‚ РёР»Рё РѕР±РЅРѕРІР»СЏРµС‚ РїР°РЅРµР»СЊ СѓРІРµРґРѕРјР»РµРЅРёР№."""
        self.notification_timer.stop()  # РћСЃС‚Р°РЅР°РІР»РёРІР°РµРј С‚Р°Р№РјРµСЂ, РµСЃР»Рё РѕРЅ Р±С‹Р» Р·Р°РїСѓС‰РµРЅ
        self.notification_label.setText(message)

        if is_finished:
            # Р—Р°РґР°С‡Р° Р·Р°РІРµСЂС€РµРЅР° - Р·РµР»РµРЅС‹Р№ С†РІРµС‚ Рё Р·Р°РїСѓСЃРє С‚Р°Р№РјРµСЂР° РЅР° СЃРєСЂС‹С‚РёРµ
            self.notification_bar.setStyleSheet("background-color: #50fa7b; color: #282a36; border-radius: 4px;")
            self.notification_timer.start(7000)  # РЎРєСЂС‹С‚СЊ С‡РµСЂРµР· 7 СЃРµРєСѓРЅРґ
        else:
            # Р—Р°РґР°С‡Р° РІ РїСЂРѕС†РµСЃСЃРµ - Р¶РµР»С‚С‹Р№ С†РІРµС‚
            self.notification_bar.setStyleSheet("background-color: #f1fa8c; color: #282a36; border-radius: 4px;")

        self.notification_bar.setVisible(True)

    def _hide_notification_bar(self):
        """РЎРєСЂС‹РІР°РµС‚ РїР°РЅРµР»СЊ СѓРІРµРґРѕРјР»РµРЅРёР№."""
        self.notification_bar.setVisible(False)

    def start_heavy_initialization(self):
        """Р—Р°РїСѓСЃРєР°РµС‚ Р·Р°РіСЂСѓР·РєСѓ С‚СЏР¶РµР»С‹С… AI-РєРѕРјРїРѕРЅРµРЅС‚РѕРІ РІ С„РѕРЅРѕРІРѕРј РїРѕС‚РѕРєРµ."""
        self.update_status("Р—Р°РіСЂСѓР·РєР° AI-РјРѕРґРµР»РµР№ (РјРѕР¶РµС‚ Р·Р°РЅСЏС‚СЊ РЅРµСЃРєРѕР»СЊРєРѕ РјРёРЅСѓС‚)...", is_error=False)
        # Р‘Р»РѕРєРёСЂСѓРµРј РєРЅРѕРїРєСѓ Р·Р°РїСѓСЃРєР° РЅР° РІСЂРµРјСЏ Р·Р°РіСЂСѓР·РєРё
        self.start_button.setEnabled(False)

        def worker():
            try:
                init_method = getattr(
                    getattr(self.trading_system, "core_system", None),
                    "initialize_heavy_components",
                    None,
                )
                if init_method:
                    init_method()
                else:
                    logger.info("initialize_heavy_components РЅРµ РЅР°Р№РґРµРЅ вЂ” РїСЂРѕРїСѓСЃРєР°РµРј")

                # РџСЂРѕРІРµСЂСЏРµРј, РґРѕСЃС‚СѓРїРµРЅ Р»Рё bridge РїРµСЂРµРґ emit
                if hasattr(self, 'bridge') and self.bridge is not None:
                    # РџРѕСЃР»Рµ Р·Р°РІРµСЂС€РµРЅРёСЏ РѕС‚РїСЂР°РІР»СЏРµРј СЃРёРіРЅР°Р» РѕР± СѓСЃРїРµС…Рµ
                    self.bridge.status_updated.emit("AI-РјРѕРґРµР»Рё Р·Р°РіСЂСѓР¶РµРЅС‹. РЎРёСЃС‚РµРјР° РіРѕС‚РѕРІР° Рє Р·Р°РїСѓСЃРєСѓ.", False)
                    self.bridge.heavy_initialization_finished.emit()
                else:
                    logger.warning("Bridge РЅРµ РґРѕСЃС‚СѓРїРµРЅ, СЃРёРіРЅР°Р» РЅРµ РѕС‚РїСЂР°РІР»РµРЅ")

                self.start_button.setEnabled(True)
            except Exception as e:
                # РџСЂРё РѕС€РёР±РєРµ РѕС‚РїСЂР°РІР»СЏРµРј СЃРёРіРЅР°Р» РѕР± РѕС€РёР±РєРµ
                logger.critical(f"РћС€РёР±РєР° РїСЂРё РёРЅРёС†РёР°Р»РёР·Р°С†РёРё: {e}", exc_info=True)
                if hasattr(self, 'bridge') and self.bridge is not None:
                    self.bridge.status_updated.emit(f"РћРЁРР‘РљРђ: {e}", True)
                # Р Р°Р·Р±Р»РѕРєРёСЂСѓРµРј РєРЅРѕРїРєСѓ, С‡С‚РѕР±С‹ РїРѕР»СЊР·РѕРІР°С‚РµР»СЊ РјРѕРі РїРѕРїСЂРѕР±РѕРІР°С‚СЊ СЃРЅРѕРІР°
                self.start_button.setEnabled(True)

        # Р—Р°РїСѓСЃРєР°РµРј РІРѕСЂРєРµСЂР° РІ РѕС‚РґРµР»СЊРЅРѕРј РїРѕС‚РѕРєРµ, С‡С‚РѕР±С‹ РЅРµ Р±Р»РѕРєРёСЂРѕРІР°С‚СЊ GUI
        init_thread = threading.Thread(target=worker, daemon=True)
        init_thread.start()

    def on_settings_saved(self):
        """
        РЎР»РѕС‚, РєРѕС‚РѕСЂС‹Р№ РІС‹Р·С‹РІР°РµС‚СЃСЏ РїРѕСЃР»Рµ СЃРѕС…СЂР°РЅРµРЅРёСЏ РЅР°СЃС‚СЂРѕРµРє РІ РґРѕС‡РµСЂРЅРµРј РѕРєРЅРµ.
        РџРµСЂРµР·Р°РіСЂСѓР¶Р°РµС‚ РєРѕРЅС„РёРіСѓСЂР°С†РёСЋ Рё РїРµСЂРµРґР°РµС‚ РµРµ РІ СЏРґСЂРѕ СЃРёСЃС‚РµРјС‹.
        """
        logger.info("РћР±РЅР°СЂСѓР¶РµРЅРѕ СЃРѕС…СЂР°РЅРµРЅРёРµ РЅР°СЃС‚СЂРѕРµРє. РџСЂРёРјРµРЅРµРЅРёРµ РёР·РјРµРЅРµРЅРёР№ РЅР° Р»РµС‚Сѓ...")
        try:
            # 1. Р—Р°РіСЂСѓР¶Р°РµРј РЅРѕРІСѓСЋ РєРѕРЅС„РёРіСѓСЂР°С†РёСЋ
            new_config = load_config()

            # 1.5. РџР РРњР•РќРЇР•Рњ РўР•РњРЈ СЃСЂР°Р·Сѓ РїРѕСЃР»Рµ Р·Р°РіСЂСѓР·РєРё РєРѕРЅС„РёРіР°
            theme_name = getattr(new_config, "GUI_THEME", "РўРµРјРЅР°СЏ")
            self.apply_style(theme_name)
            logger.info(f"[GUI] РўРµРјР° РїСЂРёРјРµРЅРµРЅР°: {theme_name}")

            # 2. РџСЂРёРјРµРЅСЏРµРј Рє С‚РѕСЂРіРѕРІРѕР№ СЃРёСЃС‚РµРјРµ
            self.trading_system.update_configuration(new_config)

            # 3. РћР±РЅРѕРІР»СЏРµРј РѕС‚РѕР±СЂР°Р¶РµРЅРёРµ РІ ControlCenterWidget
            if hasattr(self, "control_center_tab"):
                trading_settings = {
                    "RISK_PERCENTAGE": new_config.RISK_PERCENTAGE,
                    "MAX_OPEN_POSITIONS": new_config.MAX_OPEN_POSITIONS,
                    "MAX_DAILY_DRAWDOWN_PERCENT": new_config.MAX_DAILY_DRAWDOWN_PERCENT,
                    "trading_mode": getattr(new_config, "trading_mode", {"current_mode": "standard", "enabled": False}),
                }
                self.control_center_tab.update_trading_settings_display(trading_settings)
                logger.info("[GUI] ControlCenterWidget РѕР±РЅРѕРІР»С‘РЅ РїРѕСЃР»Рµ СЃРѕС…СЂР°РЅРµРЅРёСЏ РЅР°СЃС‚СЂРѕРµРє")

            # 4. РћР±РЅРѕРІР»СЏРµРј СЃС‚Р°С‚СѓСЃ Р±Р°СЂ Рё РїР»Р°РЅРёСЂРѕРІС‰РёРє
            self.update_status("РќР°СЃС‚СЂРѕР№РєРё СѓСЃРїРµС€РЅРѕ РїСЂРёРјРµРЅРµРЅС‹.", is_error=False)
            self.update_scheduler_status_display()

        except Exception as e:
            logger.error(f"РћС€РёР±РєР° РїСЂРё РїСЂРёРјРµРЅРµРЅРёРё РЅРѕРІС‹С… РЅР°СЃС‚СЂРѕРµРє: {e}", exc_info=True)
            self.update_status("РћС€РёР±РєР° РїСЂРё РїСЂРёРјРµРЅРµРЅРёРё РЅР°СЃС‚СЂРѕРµРє. РЎРј. Р»РѕРіРё.", is_error=True)

    def update_thread_status(self, thread_name: str, status: str):
        """РћР±РЅРѕРІР»СЏРµС‚ С‚РµРєСЃС‚ Рё С†РІРµС‚ РјРµС‚РєРё СЃС‚Р°С‚СѓСЃР° РїРѕС‚РѕРєР°."""
        if thread_name in self.thread_status_labels:
            label = self.thread_status_labels[thread_name]
            status_colors = {
                "RUNNING": ("#50fa7b", "Р РђР‘РћРўРђР•Рў"),
                "STOPPING": ("#f1fa8c", "РћРЎРўРђРќРћР’РљРђ..."),
                "STOPPED": ("#ff5555", "РћРЎРўРђРќРћР’Р›Р•Рќ"),
            }
            color, text = status_colors.get(status.upper(), ("#f8f8f2", status))
            label.setText(text)
            label.setStyleSheet(f"font-weight: bold; color: {color};")
            QApplication.processEvents()  # РџСЂРёРЅСѓРґРёС‚РµР»СЊРЅРѕРµ РѕР±РЅРѕРІР»РµРЅРёРµ GUI

    def _create_thread_status_panel(self) -> QGroupBox:
        """РЎРѕР·РґР°РµС‚ РїР°РЅРµР»СЊ РґР»СЏ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ СЃС‚Р°С‚СѓСЃР° С„РѕРЅРѕРІС‹С… РїРѕС‚РѕРєРѕРІ Рё Р·Р°РґР°С‡."""
        group_box = QGroupBox("РЎС‚Р°С‚СѓСЃ РЎРёСЃС‚РµРјС‹")
        layout = QGridLayout()
        group_box.setLayout(layout)
        layout.setColumnStretch(1, 1)

        # РЎР»РѕРІР°СЂСЊ РґР»СЏ Р¶РёРІС‹С… РїРѕС‚РѕРєРѕРІ
        thread_names = {
            "Trading": "РўРѕСЂРіРѕРІС‹Р№:",
            "Monitoring": "РњРѕРЅРёС‚РѕСЂРёРЅРі:",
            "Training": "R&D:",
            "Orchestrator": "РћСЂРєРµСЃС‚СЂР°С‚РѕСЂ:",
            "VectorDB Cleanup": "VectorDB Cleanup:",  # <-- РРЎРџР РђР’Р›Р•РќРР• F2
        }

        row = 0
        for key, name in thread_names.items():
            layout.addWidget(QLabel(name), row, 0, Qt.AlignRight)
            status_label = QLabel("STOPPED")
            status_label.setStyleSheet("font-weight: bold; color: #ff5555;")
            # РћР±СЉРµРґРёРЅСЏРµРј 2 Рё 3 РєРѕР»РѕРЅРєРё
            layout.addWidget(status_label, row, 1, 1, 2)
            self.thread_status_labels[key] = status_label
            row += 1

        # Р Р°Р·РґРµР»РёС‚РµР»СЊ
        separator = QFrame()
        separator.setFrameShape(QFrame.HLine)
        separator.setFrameShadow(QFrame.Sunken)
        layout.addWidget(separator, row, 0, 1, 3)
        row += 1

        # --- РќРђР§РђР›Рћ РР—РњР•РќР•РќРР™ ---
        # РњРµС‚РєР° РґР»СЏ РѕР±СЃР»СѓР¶РёРІР°РЅРёСЏ
        layout.addWidget(QLabel("РћР±СЃР»СѓР¶РёРІР°РЅРёРµ:"), row, 0, Qt.AlignRight)
        maint_label = QLabel("...")  # Р’СЂРµРјРµРЅРЅС‹Р№ С‚РµРєСЃС‚
        maint_label.setStyleSheet("color: #f1fa8c;")
        layout.addWidget(maint_label, row, 1, 1, 2)
        self.scheduler_status_labels["Maintenance"] = maint_label
        row += 1

        # РњРµС‚РєР° РґР»СЏ РѕРїС‚РёРјРёР·Р°С†РёРё
        layout.addWidget(QLabel("РћРїС‚РёРјРёР·Р°С†РёСЏ:"), row, 0, Qt.AlignRight)
        opt_label = QLabel("...")  # Р’СЂРµРјРµРЅРЅС‹Р№ С‚РµРєСЃС‚
        opt_label.setStyleSheet("color: #f1fa8c;")
        layout.addWidget(opt_label, row, 1, 1, 2)
        self.scheduler_status_labels["Optimization"] = opt_label

        return group_box

    def apply_style(self, style_name: str):
        """РџСЂРёРјРµРЅСЏРµС‚ С‚РµРјСѓ РѕС„РѕСЂРјР»РµРЅРёСЏ РєРѕ РІСЃРµРјСѓ РїСЂРёР»РѕР¶РµРЅРёСЋ."""
        logger.info(f"[Theme] === РќРђР§РђР›Рћ РЎРњР•РќР« РўР•РњР«: {style_name} ===")

        if style_name == "РЎРІРµС‚Р»Р°СЏ":
            self.setStyleSheet(LIGHT_STYLE)
            bg_color = "w"
        elif style_name == "РўРµРјРЅР°СЏ":
            self.setStyleSheet(DARK_STYLE)
            bg_color = "#282a36"
        elif style_name == "РЎС‚Р°РЅРґР°СЂС‚РЅР°СЏ":
            # РЎС‚Р°РЅРґР°СЂС‚РЅР°СЏ = СЃРІРµС‚Р»Р°СЏ С‚РµРјР° Windows СЃ Р»С‘РіРєРёРј СЃРµСЂС‹Рј С„РѕРЅРѕРј
            self.setStyleSheet("""
                QWidget { background-color: #f0f0f0; color: #000000; }
                QMainWindow, QDialog { background-color: #f0f0f0; }
                QPushButton { background-color: #e1e1e1; border: 1px solid #adadad; padding: 5px 15px; }
                QPushButton:hover { background-color: #e5f1fb; border: 1px solid #0078d7; }
                QLineEdit, QTextEdit, QPlainTextEdit { background-color: #ffffff; border: 1px solid #adadad; }
                QTabBar::tab { background-color: #e1e1e1; border: 1px solid #adadad; padding: 5px 10px; }
                QTabBar::tab:selected { background-color: #f0f0f0; border-bottom: 1px solid #f0f0f0; }
                QHeaderView::section { background-color: #e1e1e1; border: 1px solid #adadad; }
                QTableWidget, QTreeView, QListView { background-color: #ffffff; border: 1px solid #adadad; }
                QComboBox { background-color: #ffffff; border: 1px solid #adadad; }
                QSpinBox, QDoubleSpinBox { background-color: #ffffff; border: 1px solid #adadad; }
                QGroupBox { border: 1px solid #adadad; border-radius: 3px; margin-top: 10px; }
                QMenuBar { background-color: #f0f0f0; }
                QStatusBar { background-color: #f0f0f0; }
            """)
            bg_color = "#f0f0f0"
        else:
            self.setStyleSheet(DARK_STYLE)
            bg_color = "#282a36"

        logger.info(f"[Theme] Stylesheet СѓСЃС‚Р°РЅРѕРІР»РµРЅ, bg_color={bg_color}")

        # РћР±РЅРѕРІР»СЏРµРј С„РѕРЅС‹ Р’РЎР•РҐ PlotWidget
        self._update_all_plot_backgrounds(bg_color)

        # РџСЂРёРЅСѓРґРёС‚РµР»СЊРЅРѕ РѕР±РЅРѕРІР»СЏРµРј Р’РЎР• РІРёРґР¶РµС‚С‹
        QApplication.processEvents()
        updated_widgets = 0
        for widget in self.findChildren(QWidget):
            try:
                widget.style().unpolish(widget)
                widget.style().polish(widget)
                widget.update()
                updated_widgets += 1
            except Exception:
                pass

        self.style().unpolish(self)
        self.style().polish(self)
        self.update()
        QApplication.processEvents()

        logger.info(f"[Theme] === РўР•РњРђ {style_name} РџР РРњР•РќР•РќРђ === (РѕР±РЅРѕРІР»РµРЅРѕ {updated_widgets} РІРёРґР¶РµС‚РѕРІ)")

    def _update_all_plot_backgrounds(self, bg_color: str):
        """РћР±РЅРѕРІР»СЏРµС‚ С„РѕРЅС‹ Р’РЎР•РҐ pyqtgraph PlotWidget."""
        import pyqtgraph as pg

        # РќР°С…РѕРґРёРј РІСЃРµ PlotWidget С‡РµСЂРµР· РїРѕРёСЃРє РїРѕ РІСЃРµРјСѓ РґРµСЂРµРІСѓ РІРёРґР¶РµС‚РѕРІ
        all_plot_widgets = self.findChildren(pg.PlotWidget)
        logger.info(f"[Theme] РќР°Р№РґРµРЅРѕ {len(all_plot_widgets)} PlotWidget")

        success = 0
        failed = 0
        for i, pw in enumerate(all_plot_widgets):
            try:
                pw.setBackground(bg_color)
                success += 1
                if i < 5:
                    logger.debug(f"[Theme]   {i+1}. {pw.objectName() or 'unnamed'} -> {bg_color}")
            except Exception as e:
                failed += 1
                logger.warning(f"[Theme] РћС€РёР±РєР° РѕР±РЅРѕРІР»РµРЅРёСЏ С„РѕРЅР°: {e}")

        logger.info(f"[Theme] РћР±РЅРѕРІР»РµРЅРѕ {success}/{len(all_plot_widgets)} PlotWidget (РЅРµСѓРґР°С‡РЅРѕ: {failed}), bg={bg_color}")

    def _init_widgets(self):
        central_widget = QWidget()
        self.main_central_widget = central_widget
        self.setCentralWidget(central_widget)
        main_layout = QVBoxLayout(central_widget)

        # 1. РЎРѕР·РґР°РµРј С‚РµРєСЃС‚РѕРІСѓСЋ РјРµС‚РєСѓ (QLabel)
        title_label = QLabel()

        # 2. РЈСЃС‚Р°РЅР°РІР»РёРІР°РµРј С‚РµРєСЃС‚ СЃ HTML-С‚РµРіРѕРј РґР»СЏ Р·РѕР»РѕС‚РѕРіРѕ С†РІРµС‚Р°
        title_label.setText('<font color="#FFD700">Genesis--Piligrim Evolution v10.0: The Reflexive Core</font>')

        # 3. РќР°СЃС‚СЂР°РёРІР°РµРј РІРЅРµС€РЅРёР№ РІРёРґ: РІС‹СЂР°РІРЅРёРІР°РЅРёРµ РїРѕ С†РµРЅС‚СЂСѓ, РєСЂСѓРїРЅС‹Р№ Р¶РёСЂРЅС‹Р№ С€СЂРёС„С‚
        title_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        title_label.setStyleSheet("font-size: 14pt; font-weight: bold; padding: 5px;")

        # 4. Р”РѕР±Р°РІР»СЏРµРј РјРµС‚РєСѓ РІ СЃР°РјС‹Р№ РІРµСЂС… РЅР°С€РµРіРѕ РѕРєРЅР°
        main_layout.addWidget(title_label)

        top_panel = self._create_top_panel()
        main_layout.addWidget(top_panel)
        main_splitter = QSplitter(Qt.Horizontal)
        main_layout.addWidget(main_splitter)
        left_panel = self._create_left_panel()
        right_panel = self._create_right_panel()
        main_splitter.addWidget(left_panel)
        main_splitter.addWidget(right_panel)
        main_splitter.setSizes([650, 950])
        self.status_label = QLabel("РЎРёСЃС‚РµРјР° РЅРµ Р·Р°РїСѓС‰РµРЅР°.")
        sb = self.statusBar()
        if sb:
            sb.addWidget(self.status_label)

    def _create_top_panel(self):
        top_widget = QFrame()
        top_layout = QHBoxLayout(top_widget)
        top_layout.setContentsMargins(0, 0, 0, 0)

        # --- РќРћР’Р«Р™ KPI BAR ---
        kpi_bar = self._create_kpi_bar()

        control_box = QFrame()
        control_layout = QHBoxLayout(control_box)
        control_layout.setAlignment(Qt.AlignTop)

        # Р›РµРІР°СЏ РєРѕР»РѕРЅРєР°: РєРЅРѕРїРєР° Р·Р°РїСѓСЃРєР° + С‡РµРєР±РѕРєСЃ РЅР°Р±Р»СЋРґР°С‚РµР»СЏ (РІРµСЂС‚РёРєР°Р»СЊРЅРѕ)
        start_layout = QVBoxLayout()
        self.start_button = QPushButton("Р—Р°РїСѓСЃРє РЎРёСЃС‚РµРјС‹")
        self.observer_checkbox = QCheckBox("Р РµР¶РёРј РќР°Р±Р»СЋРґР°С‚РµР»СЏ")
        self.observer_checkbox.setChecked(True)
        start_layout.addWidget(self.start_button)
        start_layout.addWidget(self.observer_checkbox)
        start_layout.addStretch()
        control_layout.addLayout(start_layout)

        # РћСЃС‚Р°Р»СЊРЅС‹Рµ РєРЅРѕРїРєРё (РІС‹СЂРѕРІРЅРµРЅС‹ РїРѕ РІРµСЂС…Сѓ)
        buttons_layout = QVBoxLayout()
        buttons_layout.setAlignment(Qt.AlignTop)

        self.stop_button = QPushButton("РћСЃС‚Р°РЅРѕРІРєР°")
        self.stop_button.setEnabled(False)

        self.settings_button = QPushButton("РќР°СЃС‚СЂРѕР№РєРё")

        self.restart_system_button = QPushButton("РџРµСЂРµР·Р°РїСѓСЃС‚РёС‚СЊ РЎРёСЃС‚РµРјСѓ")
        self.restart_system_button.setStyleSheet("background-color: #ffb86c; color: #000;")

        buttons_layout.addWidget(self.stop_button)
        buttons_layout.addWidget(self.settings_button)
        buttons_layout.addWidget(self.restart_system_button)
        control_layout.addLayout(buttons_layout)

        update_box = QFrame()
        update_layout = QVBoxLayout(update_box)

        # РўРµРєСѓС‰Р°СЏ РІРµСЂСЃРёСЏ
        version_layout = QHBoxLayout()
        self.update_version_label = QLabel("рџ“¦ Р’РµСЂСЃРёСЏ: N/A")
        self.update_version_label.setStyleSheet("color: #50fa7b; font-weight: bold;")
        version_layout.addWidget(self.update_version_label)
        version_layout.addStretch()
        update_layout.addLayout(version_layout)

        # РЎС‚Р°С‚СѓСЃ РѕР±РЅРѕРІР»РµРЅРёР№
        self.update_status_label = QLabel("рџ”„ РЎС‚Р°С‚СѓСЃ: Р—Р°РіСЂСѓР·РєР°...")
        self.update_status_label.setStyleSheet("color: #f8f8f2;")
        update_layout.addWidget(self.update_status_label)

        # РњРѕРЅРёС‚РѕСЂРёРЅРі
        self.update_monitoring_label = QLabel("рџ‘ЃпёЏ РњРѕРЅРёС‚РѕСЂРёРЅРі: N/A")
        self.update_monitoring_label.setStyleSheet("color: #888;")
        update_layout.addWidget(self.update_monitoring_label)

        # РџРѕСЃР»РµРґРЅСЏСЏ РїСЂРѕРІРµСЂРєР°
        self.update_last_check_label = QLabel("вЏ° РџРѕСЃР»РµРґРЅСЏСЏ РїСЂРѕРІРµСЂРєР°: N/A")
        self.update_last_check_label.setStyleSheet("color: #888; font-size: 11px;")
        update_layout.addWidget(self.update_last_check_label)

        # РљРЅРѕРїРєР°
        self.update_button = QPushButton("в¬‡пёЏ РћР±РЅРѕРІРёС‚СЊ Рё РџРµСЂРµР·Р°РїСѓСЃС‚РёС‚СЊ")
        self.update_button.setEnabled(False)
        self.update_button.setStyleSheet("""
            QPushButton {
                background-color: #50fa7b;
                color: #282a36;
                border: none;
                padding: 8px;
                border-radius: 5px;
                font-weight: bold;
            }
            QPushButton:hover {
                background-color: #69ff94;
            }
            QPushButton:disabled {
                background-color: #44475a;
                color: #6272a4;
            }
        """)
        update_layout.addWidget(self.update_button)

        thread_status_box = self._create_thread_status_panel()
        # Р”Р»СЏ СЃС‚РёР»РёР·Р°С†РёРё, РµСЃР»Рё РїРѕРЅР°РґРѕР±РёС‚СЃСЏ
        thread_status_box.setObjectName("ThreadStatusBox")

        account_box = QFrame()

        account_layout = QVBoxLayout(account_box)
        self.balance_label = QLabel("Р‘Р°Р»Р°РЅСЃ: N/A")
        self.equity_label = QLabel("Р­РєРІРёС‚Рё: N/A")
        self.uptime_label = QLabel("Р’СЂРµРјСЏ СЂР°Р±РѕС‚С‹: -")
        self.uptime_label.setStyleSheet("font-weight: bold; color: #50fa7b;")
        self.pc_time_label = QLabel("PC Р’СЂРµРјСЏ: --:--:--")
        self.server_time_label = QLabel("Р’СЂРµРјСЏ СЃРµСЂРІРµСЂР°: --:--:--")

        account_layout.addWidget(self.balance_label)
        account_layout.addWidget(self.equity_label)
        account_layout.addWidget(self.uptime_label)
        account_layout.addWidget(self.pc_time_label)
        account_layout.addWidget(self.server_time_label)

        top_layout.addWidget(control_box)
        top_layout.addWidget(update_box)
        top_layout.addWidget(thread_status_box)
        top_layout.addWidget(self.notification_bar)
        top_layout.addWidget(kpi_bar)

        top_layout.addStretch()
        top_layout.addWidget(account_box)

        return top_widget

    def _create_kpi_bar(self) -> QGroupBox:
        """РЎРѕР·РґР°РµС‚ РІРёРґР¶РµС‚ РґР»СЏ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ РєР»СЋС‡РµРІС‹С… РјРµС‚СЂРёРє PnL Р·Р° РїРµСЂРёРѕРґ."""
        group_box = QGroupBox("PnL РїРѕ РџРµСЂРёРѕРґР°Рј")
        layout = QGridLayout()
        group_box.setLayout(layout)

        # РњРµС‚РєРё РґР»СЏ PnL (Р·Р°РєСЂС‹С‚С‹Рµ СЃРґРµР»РєРё)
        self.pnl_day_label = QLabel("Р”РµРЅСЊ: N/A")
        self.pnl_week_label = QLabel("РќРµРґРµР»СЏ: N/A")
        self.pnl_month_label = QLabel("РњРµСЃСЏС†: N/A")

        # РњРµС‚РєР° РґР»СЏ РѕС‚РєСЂС‹С‚РѕРіРѕ PnL (РЅРµР·Р°РєСЂС‹С‚С‹Рµ РїРѕР·РёС†РёРё) вЂ” С‚РѕР»СЊРєРѕ Р·РЅР°С‡РµРЅРёРµ
        self.open_pnl_label = QLabel("N/A")
        self.open_pnl_label.setToolTip("РўРµРєСѓС‰Р°СЏ РїСЂРёР±С‹Р»СЊ/СѓР±С‹С‚РѕРє РїРѕ РќР•Р·Р°РєСЂС‹С‚С‹Рј РїРѕР·РёС†РёСЏРј (Equity - Balance).")
        self.open_pnl_label.setStyleSheet("font-weight: bold; color: #8be9fd;")

        # РњРµС‚РєРё РґР»СЏ Drawdown (РЈР±С‹С‚РѕРє)
        self.dd_day_label = QLabel("DD Р”РµРЅСЊ: N/A")
        self.dd_week_label = QLabel("DD РќРµРґРµР»СЏ: N/A")
        self.dd_month_label = QLabel("DD РњРµСЃСЏС†: N/A")

        # --- Р”РћР‘РђР’Р›Р•РќРР• Р’РЎРџР›Р«Р’РђР®Р©РРҐ РџРћР”РЎРљРђР—РћРљ (TOOLTIPS) ---

        # РџРѕРґСЃРєР°Р·РєРё РґР»СЏ РџСЂРёР±С‹Р»Рё
        self.pnl_day_label.setToolTip("Р§РёСЃС‚Р°СЏ РїСЂРёР±С‹Р»СЊ/СѓР±С‹С‚РѕРє (PnL) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµРіРѕ РґРЅСЏ (00:00 UTC).")
        self.pnl_week_label.setToolTip(
            "Р§РёСЃС‚Р°СЏ РїСЂРёР±С‹Р»СЊ/СѓР±С‹С‚РѕРє (PnL) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµР№ РЅРµРґРµР»Рё (РџРѕРЅРµРґРµР»СЊРЅРёРє 00:00 UTC)."
        )
        self.pnl_month_label.setToolTip(
            "Р§РёСЃС‚Р°СЏ РїСЂРёР±С‹Р»СЊ/СѓР±С‹С‚РѕРє (PnL) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµРіРѕ РјРµСЃСЏС†Р° (1-Рµ С‡РёСЃР»Рѕ 00:00 UTC)."
        )
        self.open_pnl_label.setToolTip("РўРµРєСѓС‰Р°СЏ РїСЂРёР±С‹Р»СЊ/СѓР±С‹С‚РѕРє РїРѕ РќР•Р·Р°РєСЂС‹С‚С‹Рј РїРѕР·РёС†РёСЏРј (Equity - Balance).")

        # РџРѕРґСЃРєР°Р·РєРё РґР»СЏ РњР°РєСЃРёРјР°Р»СЊРЅРѕР№ РџСЂРѕСЃР°РґРєРё (Drawdown)
        self.dd_day_label.setToolTip("РњР°РєСЃРёРјР°Р»СЊРЅР°СЏ РїСЂРѕСЃР°РґРєР° (Max Drawdown) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµРіРѕ РґРЅСЏ.")
        self.dd_week_label.setToolTip("РњР°РєСЃРёРјР°Р»СЊРЅР°СЏ РїСЂРѕСЃР°РґРєР° (Max Drawdown) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµР№ РЅРµРґРµР»Рё.")
        self.dd_month_label.setToolTip("РњР°РєСЃРёРјР°Р»СЊРЅР°СЏ РїСЂРѕСЃР°РґРєР° (Max Drawdown) РїРѕ Р·Р°РєСЂС‹С‚С‹Рј СЃРґРµР»РєР°Рј СЃ РЅР°С‡Р°Р»Р° С‚РµРєСѓС‰РµРіРѕ РјРµСЃСЏС†Р°.")

        # ----------------------------------------------------

        # РЎС‚РёР»РёР·Р°С†РёСЏ (РґР»СЏ РЅР°РіР»СЏРґРЅРѕСЃС‚Рё)
        self.pnl_day_label.setStyleSheet("font-weight: bold; color: #50fa7b;")
        self.dd_day_label.setStyleSheet("font-weight: bold; color: #ff5555;")

        # Р Р°Р·РјРµС‰РµРЅРёРµ РІ СЃРµС‚РєРµ
        layout.addWidget(QLabel("РџСЂРёР±С‹Р»СЊ (Р·Р°РєСЂС‹С‚Рѕ):"), 0, 0)
        layout.addWidget(self.pnl_day_label, 0, 1)
        layout.addWidget(self.pnl_week_label, 0, 2)
        layout.addWidget(self.pnl_month_label, 0, 3)

        # РћС‚РєСЂС‹С‚С‹Р№ PnL вЂ” Р·Р°РіРѕР»РѕРІРѕРє РЅР°Рґ Р·РЅР°С‡РµРЅРёРµРј РІ РѕРґРЅРѕР№ РєРѕР»РѕРЅРєРµ (СЂР°СЃС‚СЏРЅСѓС‚ РЅР° 2 СЃС‚СЂРѕРєРё)
        open_pnl_col = QWidget()
        open_pnl_layout = QVBoxLayout(open_pnl_col)
        open_pnl_layout.setContentsMargins(0, 0, 0, 0)
        open_pnl_layout.setSpacing(2)
        open_pnl_layout.addWidget(QLabel("РћС‚РєСЂС‹С‚Рѕ:"))
        open_pnl_layout.addWidget(self.open_pnl_label)
        layout.addWidget(open_pnl_col, 0, 4, 2, 1)  # row=0, col=4, rowSpan=2, colSpan=1

        # РР·РјРµРЅРёРј РјРµС‚РєСѓ РґР»СЏ СЏСЃРЅРѕСЃС‚Рё
        layout.addWidget(QLabel("Max DD (%):"), 1, 0)
        layout.addWidget(self.dd_day_label, 1, 1)
        layout.addWidget(self.dd_week_label, 1, 2)
        layout.addWidget(self.dd_month_label, 1, 3)

        return group_box

    @Slot(dict)
    def update_pnl_kpis(self, kpis: dict):
        """РћР±РЅРѕРІР»СЏРµС‚ РјРµС‚РєРё PnL Рё Drawdown РёР· Р·Р°РєСЂС‹С‚С‹С… СЃРґРµР»РѕРє."""

        def format_pnl(value):
            # Р—РµР»РµРЅС‹Р№ РґР»СЏ РїСЂРёР±С‹Р»Рё, РєСЂР°СЃРЅС‹Р№ РґР»СЏ СѓР±С‹С‚РєР°
            color = "#50fa7b" if value >= 0 else "#ff5555"
            return f"<span style='font-weight: bold; color:{color}'>{value:+.2f}</span>"

        def format_dd(value):
            # РљСЂР°СЃРЅС‹Р№ РґР»СЏ РїСЂРѕСЃР°РґРєРё
            color = "#ff5555"
            return f"<span style='font-weight: bold; color:{color}'>{value:.2f}%</span>"

        # РћР±РЅРѕРІР»СЏРµРј РјРµС‚РєРё PnL
        self.pnl_day_label.setText(format_pnl(kpis.get("day_pnl", 0)))
        self.pnl_week_label.setText(format_pnl(kpis.get("week_pnl", 0)))
        self.pnl_month_label.setText(format_pnl(kpis.get("month_pnl", 0)))

        # РћР±РЅРѕРІР»СЏРµРј РјРµС‚РєРё Drawdown
        self.dd_day_label.setText(format_dd(kpis.get("day_dd", 0)))
        self.dd_week_label.setText(format_dd(kpis.get("week_dd", 0)))
        self.dd_month_label.setText(format_dd(kpis.get("month_dd", 0)))

    def _create_left_panel(self):
        left_widget = QWidget()
        left_layout = QVBoxLayout(left_widget)
        tab_widget = QTabWidget()

        # Р”РѕР±Р°РІР»СЏРµРј РѕР±СЂР°Р±РѕС‚С‡РёРє РїРµСЂРµРєР»СЋС‡РµРЅРёСЏ РІРєР»Р°РґРѕРє Р»РµРІРѕР№ РїР°РЅРµР»Рё
        tab_widget.currentChanged.connect(lambda idx: self.on_left_tab_changed(idx, tab_widget))
        logger.info("[GUI-Init] РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ Р»РµРІРѕР№ РїР°РЅРµР»Рё")

        # --- Р’РљР›РђР”РљРђ "РћРўРљР Р«РўР«Р• РџРћР—РР¦РР" (Р±РµР· РёР·РјРµРЅРµРЅРёР№) ---
        positions_tab_widget = QWidget()
        positions_tab_layout = QVBoxLayout(positions_tab_widget)
        positions_control_layout = QHBoxLayout()
        positions_control_layout.addWidget(QLabel("<b>РћС‚РєСЂС‹С‚С‹Рµ РџРѕР·РёС†РёРё</b>"))
        positions_control_layout.addStretch()
        self.close_all_pos_button = QPushButton("Р—Р°РєСЂС‹С‚СЊ РІСЃРµ")
        self.close_all_pos_button.setStyleSheet("background-color: #8B0000;")
        positions_control_layout.addWidget(self.close_all_pos_button)
        self.close_pos_button = QPushButton("Р—Р°РєСЂС‹С‚СЊ РІС‹Р±СЂР°РЅРЅСѓСЋ")
        positions_control_layout.addWidget(self.close_pos_button)

        self.positions_table = QTableView()
        self.positions_headers = [
            "РўРёРєРµС‚",
            "РЎРёРј\nРІРѕР»",
            "РЎС‚СЂР°\nС‚РµРіРёСЏ",
            "РўРёРї",
            "РћР±СЉРµРј",
            "Р¦РµРЅР°\nРѕС‚РєСЂ.",
            "РџСЂРё\nР±С‹Р»СЊ",
            "Р‘Р°СЂРѕРІ\nРІ СЃРґРµР»РєРµ",
            "РўР¤",
        ]
        self.positions_model = GenericTableModel([], self.positions_headers)
        self.positions_table.setModel(self.positions_model)
        header_pos = self.positions_table.horizontalHeader()
        header_pos.setSectionResizeMode(QHeaderView.ResizeMode.ResizeToContents)
        header_pos.setSectionResizeMode(1, QHeaderView.ResizeMode.Stretch)
        header_pos.setSectionResizeMode(2, QHeaderView.ResizeMode.Stretch)
        positions_tab_layout.addLayout(positions_control_layout)
        positions_tab_layout.addWidget(self.positions_table)
        tab_widget.addTab(positions_tab_widget, "РћС‚РєСЂС‹С‚С‹Рµ РџРѕР·РёС†РёРё")

        # --- Р’РљР›РђР”РљРђ "РРЎРўРћР РРЇ РЎР”Р•Р›РћРљ" (СЃ РёСЃРїСЂР°РІР»РµРЅРёСЏРјРё) ---
        self.history_table = QTableView()

        # +++ РќРђР§РђР›Рћ РР—РњР•РќР•РќРР™: РЈСЃС‚Р°РЅР°РІР»РёРІР°РµРј РџР РђР’РР›Р¬РќР«Р™ РїРѕСЂСЏРґРѕРє Р·Р°РіРѕР»РѕРІРєРѕРІ +++
        self.history_headers = [
            "РўРёРєРµС‚",
            "РЎРёРј\nРІРѕР»",
            "РЎС‚СЂР°\nС‚РµРіРёСЏ",
            "РўРёРї",
            "РћР±СЉРµРј",
            "Р¦РµРЅР°\nР·Р°РєСЂ.",
            "Р’СЂРµРјСЏ\nР·Р°РєСЂ.",
            "РџСЂРё\nР±С‹Р»СЊ",
            "РўР¤",
        ]
        # +++ РљРћРќР•Р¦ РР—РњР•РќР•РќРР™ +++

        self.history_model = GenericTableModel([], self.history_headers)
        self.history_table.setModel(self.history_model)

        header_hist = self.history_table.horizontalHeader()
        header_hist.setSectionResizeMode(QHeaderView.ResizeMode.ResizeToContents)
        header_hist.setSectionResizeMode(6, QHeaderView.ResizeMode.Stretch)  # Р’СЂРµРјСЏ Р·Р°РєСЂ.
        header_hist.setSectionResizeMode(7, QHeaderView.ResizeMode.Stretch)  # РЎС‚СЂР°С‚РµРіРёСЏ

        tab_widget.addTab(self.history_table, "РСЃС‚РѕСЂРёСЏ РЎРґРµР»РѕРє")

        # --- РћР‘Р©РР™ Р›Р•Р™РђРЈРў ---
        left_layout.addWidget(tab_widget)
        log_box = QFrame()
        log_layout = QVBoxLayout(log_box)

        # Р—Р°РіРѕР»РѕРІРѕРє Рё РїРµСЂРµРєР»СЋС‡Р°С‚РµР»СЊ РѕС‚Р»Р°РґРєРё
        log_header_layout = QHBoxLayout()
        log_header_layout.addWidget(QLabel("Р›РѕРіРё РЎРёСЃС‚РµРјС‹"))
        log_header_layout.addStretch()

        self.debug_log_checkbox = QCheckBox("РћС‚Р»Р°РґРєР° (Debug)")
        self.debug_log_checkbox.setToolTip("Р’РєР»СЋС‡РёС‚СЊ РїРѕРґСЂРѕР±РЅС‹Рµ С‚РµС…РЅРёС‡РµСЃРєРёРµ Р»РѕРіРё (Р±Р°Р»Р°РЅСЃ, С€Р°РіРё РјРѕРЅРёС‚РѕСЂРёРЅРіР°, СЃРёРіРЅР°Р»С‹ GUI)")
        self.debug_log_checkbox.stateChanged.connect(self._toggle_debug_logs)
        log_header_layout.addWidget(self.debug_log_checkbox)

        log_layout.addLayout(log_header_layout)

        self.log_text_edit = QTextEdit()
        self.log_text_edit.setReadOnly(True)
        log_layout.addWidget(self.log_text_edit)
        left_layout.addWidget(log_box)

        return left_widget

    def _on_backtest_type_changed(self):
        test_type = self.bt_test_type_combo.currentText()
        self.bt_strategy_combo.clear()  # РћС‡РёСЃС‚РєР° СЃРїРёСЃРєР°
        self.bt_strategy_combo.setEnabled(True)

        if test_type == "Event-Driven Backtest":
            self.bt_strategy_combo.addItem("N/A (Р’СЃСЏ СЃРёСЃС‚РµРјР°)")
            self.bt_strategy_combo.setEnabled(False)

        elif test_type == "РЎРёСЃС‚РµРјРЅС‹Р№ Р±СЌРєС‚РµСЃС‚ (Р­РєРѕСЃРёСЃС‚РµРјР°)":
            self.bt_strategy_combo.addItem("N/A (СЃРёСЃС‚РµРјР° СЂРµС€Р°РµС‚ СЃР°РјР°)")
            self.bt_strategy_combo.setEnabled(False)

        elif test_type == "РљР»Р°СЃСЃРёС‡РµСЃРєР°СЏ СЃС‚СЂР°С‚РµРіРёСЏ":
            # Р—Р°РіСЂСѓР¶Р°РµРј СЃС‚СЂР°С‚РµРіРёРё Р·Р°РЅРѕРІРѕ
            strategy_loader = StrategyLoader(self.trading_system.config)
            strategies = strategy_loader.load_strategies()

            if not strategies:
                self.bt_strategy_combo.addItem("РЎС‚СЂР°С‚РµРіРёРё РЅРµ РЅР°Р№РґРµРЅС‹")
            else:
                for s in strategies:
                    # Р”РѕР±Р°РІР»СЏРµРј РёРјСЏ РєР»Р°СЃСЃР° СЃС‚СЂР°С‚РµРіРёРё
                    self.bt_strategy_combo.addItem(s.__class__.__name__)

        elif test_type == "AI РњРѕРґРµР»СЊ":
            all_models = self.trading_system.get_all_models()
            pytorch_models = [m for m in all_models if "PyTorch" in m.get("type", "")]
            if not pytorch_models:
                self.bt_strategy_combo.addItem("РќРµС‚ СЃРѕРІРјРµСЃС‚РёРјС‹С… PyTorch РјРѕРґРµР»РµР№")
                self.bt_strategy_combo.setEnabled(False)
            else:
                for model in pytorch_models:
                    status = model.get("status", "N/A")
                    item_text = f"ID: {model.get('id')} - {model.get('symbol')} - {model.get('type')} ({status})"
                    self.bt_strategy_combo.addItem(item_text)

    def on_kg_toggle(self):
        is_checked = self.kg_enabled_checkbox.isChecked()

        # РћР±РЅРѕРІР»СЏРµРј РєРѕРЅС„РёРі РІ СЏРґСЂРµ
        if hasattr(self, "trading_system"):
            ts = getattr(self.trading_system, "core_system", None)
            if ts and hasattr(ts, "toggle_knowledge_graph"):
                ts.toggle_knowledge_graph(is_checked)

        # Р‘РµР·РѕРїР°СЃРЅРѕРµ РїРµСЂРµРєР»СЋС‡РµРЅРёРµ РІРёРґРёРјРѕСЃС‚Рё
        # РџСЂРѕРІРµСЂСЏРµРј, СЃРѕР·РґР°РЅС‹ Р»Рё СѓР¶Рµ РІРёРґР¶РµС‚С‹
        if hasattr(self, "knowledge_graph_view") and hasattr(self, "kg_disabled_label"):
            self.knowledge_graph_view.setVisible(is_checked)
            self.kg_disabled_label.setVisible(not is_checked)
        else:
            # Р•СЃР»Рё РјРµС‚РѕРґ РІС‹Р·РІР°РЅ РґРѕ РїРѕР»РЅРѕР№ РёРЅРёС†РёР°Р»РёР·Р°С†РёРё UI
            pass

    def _create_right_panel(self, vector_db_tab=None):
        right_widget = QTabWidget()

        # --- Р’РљР›РђР”РљРђ "РћРЎРќРћР’РќРћР™ Р“Р РђР¤РРљ" ---
        self.chart_layout_widget = pg.GraphicsLayoutWidget()
        right_widget.addTab(self.chart_layout_widget, "РћСЃРЅРѕРІРЅРѕР№ Р“СЂР°С„РёРє")
        self.price_plot = self.chart_layout_widget.addPlot(row=0, col=0)

        # РСЃРїРѕР»СЊР·СѓРµРј С„РѕСЂРјР°С‚РёСЂРѕРІР°РЅРёРµ РґР°С‚ РЅР° РЅРёР¶РЅРµР№ РѕСЃРё
        self.price_plot.setAxisItems({"bottom": pg.DateAxisItem()})

        grid_pen = pg.mkPen(color="#888", style=Qt.DotLine)
        self.price_plot.showGrid(x=True, y=True, alpha=0.3)
        self.price_plot.getAxis("bottom").setPen(grid_pen)
        self.price_plot.getAxis("left").setPen(grid_pen)
        self.price_plot.getAxis("left").setWidth(60)
        self.price_plot.disableAutoRange()

        self.regime_region = pg.LinearRegionItem(
            values=[0, 1], orientation="vertical", movable=False, brush=QColor(0, 0, 0, 0)
        )
        self.regime_region.setZValue(-100)
        self.price_plot.addItem(self.regime_region)
        self.regime_colors = {
            "Strong Trend": QColor(0, 255, 0, 30),
            "Weak Trend": QColor(0, 255, 0, 15),
            "High Volatility Range": QColor(255, 255, 0, 30),
            "Low Volatility Range": QColor(0, 0, 255, 20),
        }

        self.chart_layout_widget.nextRow()
        self.volume_plot = self.chart_layout_widget.addPlot(row=1, col=0)
        self.volume_plot.setMaximumHeight(150)
        self.volume_plot.showGrid(x=True, y=True, alpha=0.3)
        self.volume_plot.getAxis("bottom").setPen(grid_pen)
        self.volume_plot.getAxis("left").setPen(grid_pen)
        self.volume_plot.getAxis("left").setWidth(60)
        self.volume_plot.setXLink(self.price_plot)

        self.candlestick_item = CustomCandlestickItem()
        self.price_plot.addItem(self.candlestick_item)
        self.volume_item = BarGraphItem(x=[], height=[], width=0.8, brush="#50fa7b")
        self.ema50_item = pg.PlotDataItem(pen=pg.mkPen("c", width=2))
        self.ema200_item = pg.PlotDataItem(pen=pg.mkPen("y", width=2))
        self.trade_arrows_item = pg.ScatterPlotItem()
        self.price_plot.addItem(self.ema50_item)
        self.price_plot.addItem(self.ema200_item)
        self.price_plot.addItem(self.trade_arrows_item)
        self.volume_plot.addItem(self.volume_item)

        vLine = pg.InfiniteLine(angle=90, movable=False, pen=pg.mkPen("gray", style=Qt.DashLine))
        hLine = pg.InfiniteLine(angle=0, movable=False, pen=pg.mkPen("gray", style=Qt.DashLine))
        self.price_plot.addItem(vLine, ignoreBounds=True)
        self.price_plot.addItem(hLine, ignoreBounds=True)
        self.crosshair_label = pg.TextItem(anchor=(0, 1))
        self.price_plot.addItem(self.crosshair_label)

        def mouse_moved(evt):
            pos = evt[0]
            if self.price_plot.sceneBoundingRect().contains(pos):
                mouse_point = self.price_plot.vb.mapSceneToView(pos)
                if np.isnan(mouse_point.x()):
                    return
                timestamp = int(mouse_point.x())
                price = mouse_point.y()
                if timestamp < 0 or timestamp > 32503680000:
                    return
                vLine.setPos(timestamp)
                hLine.setPos(price)
                try:
                    time_str = datetime.fromtimestamp(timestamp).strftime("%Y-%m-%d %H:%M")
                    self.crosshair_label.setText(f"{time_str}, {price:.5f}")
                    view_range = self.price_plot.vb.viewRange()
                    self.crosshair_label.setPos(view_range[0][0], view_range[1][1])
                except (OSError, ValueError) as e:
                    logger.debug(f"РћС€РёР±РєР° РїСЂРё РѕР±РЅРѕРІР»РµРЅРёРё РїРѕР·РёС†РёРё crosshair: {e}")

        self.proxy = pg.SignalProxy(self.price_plot.scene().sigMouseMoved, rateLimit=60, slot=mouse_moved)

        # --- Р’РљР›РђР”РљРђ "Р¦Р•РќРўР  РЈРџР РђР’Р›Р•РќРРЇ" ---
        self.control_center_tab = ControlCenterWidget(
            bridge=self.bridge, config=self.config, trading_system_adapter=self.trading_system
        )
        # Р—Р°РіСЂСѓР¶Р°РµРј РЅР°С‡Р°Р»СЊРЅС‹Рµ РЅР°СЃС‚СЂРѕР№РєРё РґР»СЏ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ
        self.control_center_tab.load_initial_settings()
        logger.info("[GUI] ControlCenterWidget РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ СЃ РЅР°СЃС‚СЂРѕР№РєР°РјРё")
        right_widget.addTab(self.control_center_tab, "Р¦РµРЅС‚СЂ РЈРїСЂР°РІР»РµРЅРёСЏ")

        # --- Р’РљР›РђР”РљРђ "РђРќРђР›РРўРРљРђ" ---
        analytics_tab_widget = QWidget()
        analytics_layout = QVBoxLayout(analytics_tab_widget)

        # 1. РЎРѕР·РґР°РµРј РћРўР”Р•Р›Р¬РќР«Р™ РІРёРґР¶РµС‚ РґР»СЏ РіСЂР°С„РёРєР° РѕР±СѓС‡РµРЅРёСЏ
        self.loss_plot_widget = pg.PlotWidget(title="рџ”„ РџСЂРѕРіСЂРµСЃСЃ РѕР±СѓС‡РµРЅРёСЏ (Loss)")
        self.loss_plot = self.loss_plot_widget.getPlotItem()  # РџРѕР»СѓС‡Р°РµРј СЃР°Рј РѕР±СЉРµРєС‚ РіСЂР°С„РёРєР°
        self.loss_plot.showGrid(x=True, y=True, alpha=0.3)
        self.loss_plot.getAxis("bottom").setLabel("Р­РїРѕС…Р° РѕР±СѓС‡РµРЅРёСЏ")
        self.loss_plot.getAxis("left").setLabel("Loss")
        self.loss_curve = self.loss_plot.plot(pen="y", symbol="o", symbolBrush="y", symbolSize=3)

        # РРЅРёС†РёР°Р»РёР·РёСЂСѓРµРј РіСЂР°С„РёРє РїСѓСЃС‚С‹РјРё РґР°РЅРЅС‹РјРё РґР»СЏ РІРёРґРёРјРѕСЃС‚Рё
        self.loss_curve.setData(x=[], y=[])
        logger.info("[GUI-Analytics] Р“СЂР°С„РёРє РѕР±СѓС‡РµРЅРёСЏ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ")

        # 1.1 РќРћР’Р«Р™: РљРѕРјРїР°РєС‚РЅР°СЏ РїР°РЅРµР»СЊ СЃ РґРІСѓРјСЏ РіСЂР°С„РёРєР°РјРё РІ РѕРґРЅРѕР№ СЃС‚СЂРѕРєРµ
        compact_charts_widget = QWidget()
        compact_charts_layout = QHBoxLayout(compact_charts_widget)
        compact_charts_layout.setContentsMargins(0, 0, 0, 0)
        compact_charts_layout.setSpacing(5)

        # Р“СЂР°С„РёРє С‚РѕС‡РЅРѕСЃС‚Рё РјРѕРґРµР»РµР№
        self.model_accuracy_plot_widget = pg.PlotWidget(title="рџ“Љ РўРѕС‡РЅРѕСЃС‚СЊ")
        self.model_accuracy_plot = self.model_accuracy_plot_widget.getPlotItem()
        self.model_accuracy_plot.showGrid(x=True, y=True, alpha=0.3)
        self.model_accuracy_plot.getAxis("bottom").setLabel("РЎРёРјРІРѕР»")
        self.model_accuracy_plot.getAxis("left").setRange(0, 1)
        self.model_accuracy_bars = pg.BarGraphItem(x=[], height=[], width=0.5, brush="g")
        self.model_accuracy_plot.addItem(self.model_accuracy_bars)
        self.model_accuracy_plot.addItem(pg.InfiniteLine(angle=0, pos=0.5, pen=pg.mkPen("r", style=Qt.DashLine)))
        self.model_accuracy_data = {}
        logger.info("[GUI-Analytics] Р“СЂР°С„РёРє С‚РѕС‡РЅРѕСЃС‚Рё РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ")

        # Р“СЂР°С„РёРє РїСЂРѕРіСЂРµСЃСЃР° РїРµСЂРµРѕР±СѓС‡РµРЅРёСЏ
        self.retrain_progress_widget = pg.PlotWidget(title="вЏ° Р”Рѕ РїРµСЂРµРѕР±СѓС‡РµРЅРёСЏ (С‡)")
        self.retrain_progress_plot = self.retrain_progress_widget.getPlotItem()
        self.retrain_progress_plot.showGrid(x=True, y=True, alpha=0.3)
        self.retrain_progress_plot.getAxis("bottom").setLabel("РЎРёРјРІРѕР»")
        self.retrain_progress_plot.getAxis("left").setLabel("Р§Р°СЃРѕРІ")
        self.retrain_progress_plot.getAxis("left").setRange(0, 3)

        # РљР РРўРР§РќРћ: Verical line (РїРѕСЂРѕРі) РІРјРµСЃС‚Рѕ horizontal вЂ” angle=90 СЌС‚Рѕ РІРµСЂС‚РёРєР°Р»СЊРЅР°СЏ Р»РёРЅРёСЏ
        # РќРѕ Р»СѓС‡С€Рµ РёСЃРїРѕР»СЊР·РѕРІР°С‚СЊ РіРѕСЂРёР·РѕРЅС‚Р°Р»СЊРЅСѓСЋ РЅР° Y=1.0 (angle=0)
        self.retrain_progress_threshold_line = pg.InfiniteLine(
            angle=0,  # Р“РѕСЂРёР·РѕРЅС‚Р°Р»СЊРЅР°СЏ Р»РёРЅРёСЏ
            pos=1.0,  # РќР° СѓСЂРѕРІРЅРµ Y=1.0 С‡Р°СЃ
            pen=pg.mkPen("y", width=2, style=Qt.PenStyle.DashLine),
            label="РџРѕСЂРѕРі: 1С‡",
            labelOpts={"position": 0.98, "color": (255, 255, 0), "movable": False},
        )
        self.retrain_progress_plot.addItem(self.retrain_progress_threshold_line)

        self.retrain_progress_bars = pg.BarGraphItem(
            x=[], height=[], width=0.6, brush="b"  # РЈРІРµР»РёС‡РµРЅРѕ СЃ 0.5 РґР»СЏ Р»СѓС‡С€РµР№ РІРёРґРёРјРѕСЃС‚Рё
        )
        self.retrain_progress_plot.addItem(self.retrain_progress_bars)
        self.retrain_progress_data = {}
        logger.info("[GUI-Analytics] Р“СЂР°С„РёРє РїСЂРѕРіСЂРµСЃСЃР° РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ")

        compact_charts_layout.addWidget(self.model_accuracy_plot_widget, 1)
        compact_charts_layout.addWidget(self.retrain_progress_widget, 1)

        # 2. РЎРѕР·РґР°РµРј РћРўР”Р•Р›Р¬РќР«Р™ РІРёРґР¶РµС‚ РґР»СЏ РіСЂР°С„РёРєР° P&L
        self.pnl_plot_widget = pg.PlotWidget(title="РљСЂРёРІР°СЏ РґРѕС…РѕРґРЅРѕСЃС‚Рё (P&L)")
        self.pnl_plot = self.pnl_plot_widget.getPlotItem()
        self.pnl_plot.showGrid(x=True, y=True, alpha=0.3)
        self.pnl_plot.getAxis("left").setLabel("Р‘Р°Р»Р°РЅСЃ", units="USD")
        self.pnl_plot.setAxisItems({"bottom": pg.DateAxisItem()})
        self.pnl_curve = self.pnl_plot.plot(pen="g")

        # 3. РЎРѕР·РґР°РµРј РћРўР”Р•Р›Р¬РќР«Р™ РІРёРґР¶РµС‚ РґР»СЏ РіСЂР°С„РёРєР° СЂРµР¶РёРјР° РЅР°Р±Р»СЋРґР°С‚РµР»СЏ
        self.observer_pnl_plot_widget = pg.PlotWidget(title="Р”РѕС…РѕРґРЅРѕСЃС‚СЊ (Р РµР¶РёРј РќР°Р±Р»СЋРґР°С‚РµР»СЏ)")
        self.observer_pnl_plot = self.observer_pnl_plot_widget.getPlotItem()
        self.observer_pnl_plot.showGrid(x=True, y=True, alpha=0.3)
        self.observer_pnl_plot.getAxis("left").setLabel("Р‘Р°Р»Р°РЅСЃ (СЃРёРјСѓР»СЏС†РёСЏ)", units="USD")
        self.observer_pnl_plot.getAxis("bottom").setLabel("РљРѕР»РёС‡РµСЃС‚РІРѕ РІРёСЂС‚СѓР°Р»СЊРЅС‹С… СЃРґРµР»РѕРє")
        self.observer_pnl_curve = self.observer_pnl_plot.plot(pen=pg.mkPen("c", width=2))

        # РћС€РёР±РєР° РїСЂРµРґСЃРєР°Р·Р°РЅРёР№ (Drift)
        self.drift_plot_widget = pg.PlotWidget(title="РћС€РёР±РєР° РїСЂРµРґСЃРєР°Р·Р°РЅРёР№ AI (Concept Drift)")
        self.drift_plot = self.drift_plot_widget.getPlotItem()
        self.drift_plot.showGrid(x=True, y=True, alpha=0.3)
        self.drift_plot.getAxis("bottom").setLabel("Р’СЂРµРјСЏ")
        self.drift_plot.getAxis("left").setLabel("РћС€РёР±РєР° (APE)")
        self.drift_plot.setAxisItems({"bottom": pg.DateAxisItem()})

