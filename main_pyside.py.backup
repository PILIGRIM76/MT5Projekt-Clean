        # РРќРР¦РРђР›РР—РђР¦РРЇ Р РРЎРљ-РњР•РќР•Р”Р–Р•Р Рђ Р ML-РџР Р•Р”РРљРўРћР Рђ
        logger.info("=== РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ RiskManager Рё MLPredictor ===")
        try:
            from src.core.risk_manager import RiskManager
