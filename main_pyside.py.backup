def check_and_run_setup():
    """РџСЂРѕРІРµСЂРєР° РєРѕРЅС„РёРіСѓСЂР°С†РёРё Рё Р·Р°РїСѓСЃРє РјР°СЃС‚РµСЂР° РЅР°СЃС‚СЂРѕР№РєРё РїСЂРё РЅРµРѕР±С…РѕРґРёРјРѕСЃС‚Рё"""
    # РћРїСЂРµРґРµР»СЏРµРј РїСѓС‚СЊ Рє РєРѕРЅС„РёРіСѓ
    if getattr(sys, "frozen", False):
        base_path = Path(sys.executable).parent
    else:
        base_path = Path(__file__).parent

    config_path = base_path / "configs" / "settings.json"

    needs_setup = False
    reason = ""

    # РџСЂРѕРІРµСЂРєР° СЃСѓС‰РµСЃС‚РІРѕРІР°РЅРёСЏ РєРѕРЅС„РёРіР°
    if not config_path.exists():
        needs_setup = True
        reason = "Р¤Р°Р№Р» РєРѕРЅС„РёРіСѓСЂР°С†РёРё РЅРµ РЅР°Р№РґРµРЅ"
    else:
        # РџСЂРѕРІРµСЂРєР° РєСЂРёС‚РёС‡РµСЃРєРёС… РїР°СЂР°РјРµС‚СЂРѕРІ
        try:
            import json

            with open(config_path, "r", encoding="utf-8") as f:
                content = "".join(line for line in f if not line.strip().startswith("//"))
                config = json.loads(content)

            # РџСЂРѕРІРµСЂРєР° РѕР±СЏР·Р°С‚РµР»СЊРЅС‹С… РїРѕР»РµР№
            required_fields = ["MT5_LOGIN", "MT5_PASSWORD", "MT5_SERVER", "MT5_PATH"]
            missing_fields = []
            for field in required_fields:
                if field not in config or not config[field]:
                    missing_fields.append(field)

            if missing_fields:
                needs_setup = True
                reason = f"РћС‚СЃСѓС‚СЃС‚РІСѓСЋС‚ РѕР±СЏР·Р°С‚РµР»СЊРЅС‹Рµ РїР°СЂР°РјРµС‚СЂС‹: {', '.join(missing_fields)}"

            # РџСЂРѕРІРµСЂРєР° РїСѓС‚РµР№
            if "MT5_PATH" in config and config["MT5_PATH"]:
                mt5_path = Path(config["MT5_PATH"])
                if not mt5_path.exists():
                    needs_setup = True
                    reason = f"MT5 С‚РµСЂРјРёРЅР°Р» РЅРµ РЅР°Р№РґРµРЅ РїРѕ РїСѓС‚Рё: {config['MT5_PATH']}"

        except Exception as e:
            needs_setup = True
            reason = f"РћС€РёР±РєР° С‡С‚РµРЅРёСЏ РєРѕРЅС„РёРіСѓСЂР°С†РёРё: {e}"

    if needs_setup:
        print("\n" + "=" * 60)
        print("  [!] РўР Р•Р‘РЈР•РўРЎРЇ РќРђРЎРўР РћР™РљРђ РЎРРЎРўР•РњР«")
        print("=" * 60)
        print(f"\nРџСЂРёС‡РёРЅР°: {reason}")
        print("\nР—Р°РїСѓСЃРє РјР°СЃС‚РµСЂР° РЅР°СЃС‚СЂРѕР№РєРё...\n")

        # Р—Р°РїСѓСЃРє РјР°СЃС‚РµСЂР° РЅР°СЃС‚СЂРѕР№РєРё
        setup_script = base_path / "setup_launcher.py"
        if setup_script.exists():
            if getattr(sys, "frozen", False):
                # Р’ Р·Р°РјРѕСЂРѕР¶РµРЅРЅРѕРј РІРёРґРµ Р·Р°РїСѓСЃРєР°РµРј С‡РµСЂРµР· exec
                os.execv(sys.executable, [sys.executable, str(setup_script)])
            else:
                os.execv(sys.executable, [sys.executable, str(setup_script)])
        else:
            print(f"[ERROR] Р¤Р°Р№Р» РјР°СЃС‚РµСЂР° РЅР°СЃС‚СЂРѕР№РєРё РЅРµ РЅР°Р№РґРµРЅ: {setup_script}")
            print("Р—Р°РїСѓСЃС‚РёС‚Рµ setup_launcher.py РІСЂСѓС‡РЅСѓСЋ")
            sys.exit(1)


# Р—Р°РїСѓСЃРєР°РµРј РїСЂРѕРІРµСЂРєСѓ РїРµСЂРµРґ РІСЃРµРј РѕСЃС‚Р°Р»СЊРЅС‹Рј
check_and_run_setup()
