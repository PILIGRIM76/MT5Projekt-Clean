        # 2. РЎРѕР·РґР°РµРј WebEngineView (РЎР°Рј РіСЂР°С„)
        self.knowledge_graph_view = QWebEngineView()
        # Р”РµР»Р°РµРј С„РѕРЅ РїСЂРѕР·СЂР°С‡РЅС‹Рј РґР»СЏ РєСЂР°СЃРѕС‚С‹
        self.knowledge_graph_view.page().setBackgroundColor(Qt.transparent)

        # 3. РЎРѕР·РґР°РµРј РјРµС‚РєСѓ-Р·Р°РіР»СѓС€РєСѓ
        self.kg_disabled_label = QLabel("Р’РёР·СѓР°Р»РёР·Р°С†РёСЏ РіСЂР°С„Р° Р·РЅР°РЅРёР№ РѕС‚РєР»СЋС‡РµРЅР°.\nРђРЅР°Р»РёР· СЃРІСЏР·РµР№ РІ С„РѕРЅРµ РїСЂРѕРґРѕР»Р¶Р°РµС‚СЃСЏ.")
        self.kg_disabled_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.kg_disabled_label.setStyleSheet("font-size: 14px; color: gray; padding: 20px; border: 2px dashed #444;")

        # 4. Р”РѕР±Р°РІР»СЏРµРј РІРёРґР¶РµС‚С‹ РІ layout
        kg_layout.addWidget(self.knowledge_graph_view)
        kg_layout.addWidget(self.kg_disabled_label)

        # 5. РќРђРЎРўР РћР™РљРђ РњРћРЎРўРђ РЎ JS (РљР РРўРР§Р•РЎРљР Р’РђР–РќРђРЇ Р§РђРЎРўР¬)

        # РЎРѕР·РґР°РµРј РѕР±СЉРµРєС‚ Р±СЌРєРµРЅРґР°
        self.graph_backend = GraphBackend(self)

        # !!! Р’РђР–РќРћ: РЎРѕР·РґР°РµРј РєР°РЅР°Р» СЃ СЂРѕРґРёС‚РµР»РµРј (self), С‡С‚РѕР±С‹ СЃР±РѕСЂС‰РёРє РјСѓСЃРѕСЂР° РЅРµ СѓРґР°Р»РёР» РµРіРѕ !!!
        self.channel = QWebChannel(self)

        # Р РµРіРёСЃС‚СЂРёСЂСѓРµРј РѕР±СЉРµРєС‚ РїРѕРґ РёРјРµРЅРµРј "backend" (РєР°Рє РІ HTML)
        self.channel.registerObject("backend", self.graph_backend)

        # РЈСЃС‚Р°РЅР°РІР»РёРІР°РµРј РєР°РЅР°Р» РЅР° СЃС‚СЂР°РЅРёС†Сѓ
        self.knowledge_graph_view.page().setWebChannel(self.channel)

        # 6. Р—Р°РіСЂСѓР·РєР° HTML С„Р°Р№Р»Р°
        project_root = os.path.dirname(os.path.abspath(__file__))
        graph_html_path = os.path.join(project_root, "assets", "graph_view.html")

        if os.path.exists(graph_html_path):
            # РСЃРїРѕР»СЊР·СѓРµРј QTimer РґР»СЏ РЅРµР±РѕР»СЊС€РѕР№ Р·Р°РґРµСЂР¶РєРё, С‡С‚РѕР±С‹ РґРІРёР¶РѕРє СѓСЃРїРµР» РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°С‚СЊСЃСЏ
            QTimer.singleShot(100, lambda: self.knowledge_graph_view.setUrl(QUrl.fromLocalFile(graph_html_path)))
        else:
            logger.error(f"РќРµ РЅР°Р№РґРµРЅ С„Р°Р№Р» РґР»СЏ РІРёР·СѓР°Р»РёР·Р°С†РёРё РіСЂР°С„Р°: {graph_html_path}")
            self.knowledge_graph_view.setHtml(f"<h3 style='color:red'>Р¤Р°Р№Р» РЅРµ РЅР°Р№РґРµРЅ: {graph_html_path}</h3>")

        right_widget.addTab(knowledge_graph_tab, "Р“СЂР°С„ Р—РЅР°РЅРёР№")

        # --- Р’РљР›РђР”РљРђ "Р’Р•РљРўРћР РќРђРЇ Р‘Р” (RAG)" ---
        vector_db_tab = self._create_vector_db_tab()
        right_widget.addTab(vector_db_tab, "Р’РµРєС‚РѕСЂРЅР°СЏ Р‘Р” (RAG)")

        # --- Р’РљР›РђР”РљРђ "РђРќРђР›РР— РЎР”Р•Р›РљР (XAI)" ---
        xai_tab_widget = QWidget()
        xai_layout = QVBoxLayout(xai_tab_widget)
        self.xai_label = QLabel("РљР»РёРєРЅРёС‚Рµ РЅР° СЃРґРµР»РєСѓ РІ 'РСЃС‚РѕСЂРёРё РЎРґРµР»РѕРє' РґР»СЏ Р°РЅР°Р»РёР·Р°")
        self.xai_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.xai_web_view = QWebEngineView()
        self.xai_web_view.setHtml(
            "<html><body style='background-color:#282a36;'><h3 style='color:#f8f8f2; text-align:center;'>РћР¶РёРґР°РЅРёРµ РґР°РЅРЅС‹С…...</h3></body></html>"
        )
        feedback_panel = QFrame()
        feedback_layout = QHBoxLayout(feedback_panel)
        feedback_panel.setLayout(feedback_layout)
        self.good_trade_button = QPushButton("рџ‘Ќ РҐРѕСЂРѕС€РµРµ СЂРµС€РµРЅРёРµ")
        self.good_trade_button.setStyleSheet("background-color: #50fa7b; color: #000;")
        self.good_trade_button.setEnabled(False)
        self.bad_trade_button = QPushButton("рџ‘Ћ РџР»РѕС…РѕРµ СЂРµС€РµРЅРёРµ")
        self.bad_trade_button.setStyleSheet("background-color: #ff5555;")
        self.bad_trade_button.setEnabled(False)
        feedback_layout.addStretch()
