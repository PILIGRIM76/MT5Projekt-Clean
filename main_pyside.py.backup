    def show_scanner_context_menu(self, pos):
        """РљРѕРЅС‚РµРєСЃС‚РЅРѕРµ РјРµРЅСЋ РґР»СЏ С‚Р°Р±Р»РёС†С‹ Scanner"""
        menu = QMenu(self)
        refresh_action = menu.addAction("РћР±РЅРѕРІРёС‚СЊ РґР°РЅРЅС‹Рµ")
        refresh_action.triggered.connect(self.refresh_scanner_data)

        export_action = menu.addAction("Р­РєСЃРїРѕСЂС‚ РІ CSV")
        export_action.triggered.connect(self.export_scanner_to_csv)

        menu.exec_(self.scanner_table.mapToGlobal(pos))

