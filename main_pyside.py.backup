from src.gui.trading_system_adapter import PySideTradingSystem


class MainWindow(QMainWindow):
    def __init__(self, trading_system_adapter: PySideTradingSystem, config: Settings):
        super().__init__()
        self.setWindowTitle("Genesis v24.0: Reflexive Core")

        logger.info("=== РќРђР§РђР›Рћ РРќРР¦РРђР›РР—РђР¦РР MainWindow ===")

        # 1. РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ QThreadPool РґР»СЏ СѓРїСЂР°РІР»РµРЅРёСЏ С„РѕРЅРѕРІС‹РјРё Р·Р°РґР°С‡Р°РјРё
        self.threadpool = QThreadPool()
        # РћРіСЂР°РЅРёС‡РёРІР°РµРј РєРѕР»РёС‡РµСЃС‚РІРѕ РїРѕС‚РѕРєРѕРІ РґР»СЏ I/O-bound Р·Р°РґР°С‡
        self.threadpool.setMaxThreadCount(10)
        logger.info(f"QThreadPool РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅ СЃ РјР°РєСЃ. {self.threadpool.maxThreadCount()} РїРѕС‚РѕРєР°РјРё.")

        # РРЅРёС†РёР°Р»РёР·Р°С†РёСЏ РѕСЃРЅРѕРІРЅС‹С… РѕР±СЉРµРєС‚РѕРІ
        self.config = config
        self.trading_system = trading_system_adapter
        self.bridge = self.trading_system.bridge
        # sound_manager Р±РµСЂС‘Рј РёР· Р°РґР°РїС‚РµСЂР° (РЅРѕРІР°СЏ Р°СЂС…РёС‚РµРєС‚СѓСЂР°)
