@echo off
chcp 65001 >nul
echo ================================================================================
echo УМНАЯ СИСТЕМА ПЕРЕОБУЧЕНИЯ МОДЕЛЕЙ
echo ================================================================================
echo.
echo Эта утилита автоматически:
echo 1. Анализирует ВСЕ доступные символы в MT5 (500+)
echo 2. Отбирает только ликвидные инструменты с хорошими данными
echo 3. Обучает модели параллельно (не зависает)
echo 4. Сохраняет результаты в базу данных
echo.
echo ================================================================================
echo.

set /p max_symbols="Сколько символов обучить? (по умолчанию 30): "
if "%max_symbols%"=="" set max_symbols=30

set /p max_workers="Сколько параллельных потоков? (по умолчанию 3): "
if "%max_workers%"=="" set max_workers=3

echo.
echo Запускаем обучение %max_symbols% символов в %max_workers% потоках...
echo.

python smart_retrain.py --max-symbols %max_symbols% --max-workers %max_workers%

echo.
echo ================================================================================
echo ОБУЧЕНИЕ ЗАВЕРШЕНО!
echo ================================================================================
echo.
pause
