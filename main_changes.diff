+    def _safe_async_call(self, async_method, *args, **kwargs):
+        """
+        Безопасный вызов async метода из синхронного GUI кода.
+
+        Создаёт новый event loop и запускает async метод в отдельном потоке.
+        """
+        import asyncio
+        import threading
+
+        def run_async():
+            try:
+                # Проверяем, есть ли уже running loop в этом потоке
+                try:
+                    loop = asyncio.get_running_loop()
+                    # Если loop уже есть — создаём task
+                    asyncio.create_task(async_method(*args, **kwargs))
+                except RuntimeError:
+                    # Нет running loop — создаём новый
+                    loop = asyncio.new_event_loop()
+                    loop.run_until_complete(async_method(*args, **kwargs))
+                    loop.close()
+            except Exception as e:
+                logger.error(f"Ошибка в async вызове {async_method.__name__}: {e}", exc_info=True)
+
+        # Запускаем в отдельном потоке чтобы не блокировать GUI
+        thread = threading.Thread(target=run_async, daemon=True)
+        thread.start()
+
+    def _safe_async_call_with_callback(self, async_method, callback, *args, **kwargs):
+        """
+        Безопасный вызов async метода с callback для результата.
+        """
+        import asyncio
+        import threading
+        from PySide6.QtCore import QTimer
+
+        def run_async():
+            try:
+                try:
+                    loop = asyncio.get_running_loop()
+                    task = asyncio.create_task(async_method(*args, **kwargs))
+                    # Ждём результат
+                    result = loop.run_until_complete(task)
+                except RuntimeError:
+                    loop = asyncio.new_event_loop()
+                    result = loop.run_until_complete(async_method(*args, **kwargs))
+                    loop.close()
+
+                # Вызываем callback в главном потоке через QTimer
+                QTimer.singleShot(0, lambda: callback(result))
+            except Exception as e:
+                logger.error(f"Ошибка в async вызове {async_method.__name__}: {e}", exc_info=True)
+                QTimer.singleShot(0, lambda: callback({}))
+
+        thread = threading.Thread(target=run_async, daemon=True)
+        thread.start()
+
