/* ============================================================
   Genesis Trading System — Light Theme (Professional)
   Файл: light_theme.qss
   ============================================================ */

/* --- Палитра ---
   Фон окна:          #F5F7FA  (холодный светло-серый)
   Фон панелей:       #FFFFFF  (белый)
   Фон карточек:      #F0F2F5
   Основной текст:    #1A1D23
   Вторичный текст:   #5F6980
   Акцент (primary):  #3B82F6  (синий)
   Акцент hover:      #2563EB
   Success:           #10B981
   Warning:           #F59E0B
   Danger:            #EF4444
   Границы:           #E2E6EE
   Таблица header:    #EEF1F6
   Таблица row hover: #F7F9FC
   Shadow (box):      rgba(0,0,0,0.06)
*/

/* ===== GLOBAL ===== */
QWidget {
    font-family: "Segoe UI", "Inter", "Roboto", sans-serif;
    font-size: 10pt;
    color: #1A1D23;
}

QMainWindow, QDialog {
    background-color: #F5F7FA;
}

/* ===== КАСТОМНАЯ РАМКА ОКНА (Title Bar) ===== */
#CustomTitleBar {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                stop:0 #FFFFFF, stop:1 #F0F2F5);
    border-bottom: 1px solid #E2E6EE;
    min-height: 36px;
    max-height: 36px;
}

#CustomTitleBar QLabel {
    color: #1A1D23;
    font-size: 11pt;
    font-weight: 600;
    padding-left: 12px;
}

#TitleMinimizeButton, #TitleMaximizeButton, #TitleCloseButton {
    border: none;
    background: transparent;
    min-width: 36px;
    max-width: 36px;
    min-height: 36px;
    max-height: 36px;
    font-size: 14px;
    color: #5F6980;
}

#TitleMinimizeButton:hover, #TitleMaximizeButton:hover {
    background-color: #E2E6EE;
    color: #1A1D23;
}

#TitleCloseButton:hover {
    background-color: #EF4444;
    color: #FFFFFF;
}

/* ===== КАРТОЧКИ / ПАНЕЛИ ===== */
#CardFrame, .CardFrame {
    background-color: #FFFFFF;
    border: 2px solid #CBD5E1;
    border-radius: 8px;
}

QFrame#KpiBar {
    background-color: #FFFFFF;
    border-bottom: 2px solid #CBD5E1;
    border-radius: 0px;
}

QFrame#NotificationBar {
    background-color: #FFFFFF;
    border-bottom: 2px solid #CBD5E1;
    border-radius: 6px;
}

/* Общий стиль для всех QFrame (панели, разделители) */
QFrame {
    border: 1.5px solid #D1D8E0;
    border-radius: 4px;
    background-color: #FFFFFF;
}

/* ===== КНОПКИ ===== */
QPushButton {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DE;
    padding: 7px 16px;
    border-radius: 6px;
    color: #1A1D23;
    font-weight: 500;
    min-height: 28px;
}

QPushButton:hover {
    background-color: #F7F9FC;
    border-color: #3B82F6;
    color: #3B82F6;
}

QPushButton:pressed {
    background-color: #EEF1F6;
    border-color: #2563EB;
}

QPushButton:disabled {
    background-color: #F0F2F5;
    color: #A0A7B8;
    border-color: #E2E6EE;
}

/* Primary button */
QPushButton#PrimaryButton, .PrimaryButton {
    background-color: #3B82F6;
    border: 1px solid #3B82F6;
    color: #FFFFFF;
}

QPushButton#PrimaryButton:hover, .PrimaryButton:hover {
    background-color: #2563EB;
    border-color: #2563EB;
}

QPushButton#PrimaryButton:pressed, .PrimaryButton:pressed {
    background-color: #1D4ED8;
}

/* Success button */
QPushButton#SuccessButton, .SuccessButton {
    background-color: #10B981;
    border: 1px solid #10B981;
    color: #FFFFFF;
}

QPushButton#SuccessButton:hover {
    background-color: #059669;
}

/* Danger button */
QPushButton#DangerButton, .DangerButton {
    background-color: #EF4444;
    border: 1px solid #EF4444;
    color: #FFFFFF;
}

QPushButton#DangerButton:hover {
    background-color: #DC2626;
}

/* Checkable buttons (toggle) */
QPushButton:checkable:checked {
    background-color: #3B82F6;
    border: 1px solid #3B82F6;
    color: #FFFFFF;
}

/* ===== ПОЛЯ ВВОДА ===== */
QLineEdit {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    padding: 6px 10px;
    background-color: #FFFFFF;
    color: #1A1D23;
    selection-background-color: #3B82F6;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border: 2px solid #3B82F6;
}

QTextEdit {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    padding: 8px;
    background-color: #FFFFFF;
    color: #1A1D23;
    selection-background-color: #3B82F6;
    selection-color: #FFFFFF;
}

QTextEdit:focus {
    border: 2px solid #3B82F6;
}

QPlainTextEdit {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    padding: 8px;
    background-color: #FFFFFF;
    color: #1A1D23;
}

QComboBox {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    padding: 6px 10px;
    background-color: #FFFFFF;
    color: #1A1D23;
    min-height: 28px;
}

QComboBox:hover {
    border-color: #3B82F6;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DE;
    border-radius: 6px;
    selection-background-color: #F0F4FF;
    selection-color: #1A1D23;
    outline: none;
    padding: 4px;
}

QSpinBox, QDoubleSpinBox {
    border: 1px solid #D1D5DE;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: #FFFFFF;
    color: #1A1D23;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1.5px solid #3B82F6;
}

QDateEdit {
    border: 1px solid #D1D5DE;
    border-radius: 6px;
    padding: 6px 10px;
    background-color: #FFFFFF;
    color: #1A1D23;
}

/* ===== ТАБЛИЦЫ ===== */
QTableView {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    background-color: #FFFFFF;
    gridline-color: #D1D8E0;
    alternate-background-color: #F7F9FC;
    selection-background-color: #E0E7FF;
    selection-color: #1A1D23;
}

QTableView::item:hover {
    background-color: #F0F4FF;
}

QTableWidget {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    background-color: #FFFFFF;
    gridline-color: #D1D8E0;
    selection-background-color: #E0E7FF;
    selection-color: #1A1D23;
}

QHeaderView::section {
    background-color: #EEF1F6;
    color: #5F6980;
    font-weight: 600;
    font-size: 9pt;
    padding: 6px 8px;
    border: none;
    border-bottom: 1px solid #E2E6EE;
    border-right: 1px solid #E2E6EE;
}

QHeaderView::section:first {
    border-top-left-radius: 6px;
}

QHeaderView::section:last {
    border-top-right-radius: 6px;
    border-right: none;
}

QHeaderView::section:hover {
    background-color: #E2E6EE;
    color: #1A1D23;
}

/* ===== ВКЛАДКИ (Tabs) ===== */
QTabWidget::pane {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    background-color: #FFFFFF;
    top: -1px;
}

QTabWidget::tab-bar {
    alignment: left;
}

QTabBar::tab {
    background: #F0F2F5;
    color: #5F6980;
    border: 1px solid #E2E6EE;
    border-bottom: none;
    padding: 8px 18px;
    margin-right: 2px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    font-weight: 500;
}

QTabBar::tab:hover {
    background: #E8EBF1;
    color: #1A1D23;
}

QTabBar::tab:selected {
    background: #FFFFFF;
    color: #3B82F6;
    font-weight: 600;
    border-bottom: 2px solid #3B82F6;
}

QTabBar::tab:!selected {
    margin-top: 2px;
}

/* ===== ГРУППЫ ===== */
QGroupBox {
    background-color: #FFFFFF;
    border: 2px solid #CBD5E1;
    border-radius: 8px;
    margin-top: 10px;
    padding-top: 16px;
    font-weight: 600;
    font-size: 10pt;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 6px;
    color: #3B82F6;
    background-color: #FFFFFF;
}

/* ===== ПРОГРЕСС-БАРЫ ===== */
QProgressBar {
    border: 1px solid #D1D5DE;
    border-radius: 6px;
    text-align: center;
    color: #1A1D23;
    background-color: #F0F2F5;
    min-height: 16px;
    max-height: 16px;
}

QProgressBar::chunk {
    background-color: #3B82F6;
    border-radius: 5px;
    width: 10px;
    margin: 1px;
}

QProgressBar#DrawdownProgressBar::chunk {
    background-color: #EF4444;
}

/* ===== СЛАЙДЕРЫ ===== */
QSlider::groove:horizontal {
    border: 1px solid #D1D5DE;
    border-radius: 4px;
    height: 6px;
    background-color: #F0F2F5;
}

QSlider::handle:horizontal {
    background-color: #3B82F6;
    border: 2px solid #FFFFFF;
    border-radius: 8px;
    width: 18px;
    height: 18px;
    margin: -6px 0;
}

QSlider::handle:horizontal:hover {
    background-color: #2563EB;
    width: 22px;
    height: 22px;
    margin: -8px 0;
}

QSlider::sub-page:horizontal {
    background-color: #3B82F6;
    border-radius: 4px;
}

/* ===== ЧЕКБОКСЫ ===== */
QCheckBox {
    spacing: 8px;
    color: #1A1D23;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1.5px solid #D1D5DE;
    border-radius: 4px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:hover {
    border-color: #3B82F6;
}

QCheckBox::indicator:checked {
    background-color: #3B82F6;
    border-color: #3B82F6;
    image: url(data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iOSIgdmlld0JveD0iMCAwIDEyIDkiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEgNEw0LjUgNy41TDExIDEiIHN0cm9rZT0id2hpdGUiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+);
}

/* ===== РАДИОКНОПКИ ===== */
QRadioButton {
    spacing: 8px;
    color: #1A1D23;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1.5px solid #D1D5DE;
    border-radius: 9px;
    background-color: #FFFFFF;
}

QRadioButton::indicator:hover {
    border-color: #3B82F6;
}

QRadioButton::indicator:checked {
    border-color: #3B82F6;
    background-color: #3B82F6;
    padding: 3px;
}

/* ===== СКРОЛЛБАРЫ ===== */
QScrollBar:vertical {
    border: none;
    background-color: #F5F7FA;
    width: 10px;
    border-radius: 5px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #C4CAD4;
    border-radius: 5px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background-color: #A8B0BE;
}

QScrollBar::handle:vertical:pressed {
    background-color: #8E99A9;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: none;
    background-color: #F5F7FA;
    height: 10px;
    border-radius: 5px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background-color: #C4CAD4;
    border-radius: 5px;
    min-width: 24px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #A8B0BE;
}

/* ===== СПЛИТТЕРЫ ===== */
QSplitter::handle {
    background-color: #E2E6EE;
}

QSplitter::handle:horizontal {
    width: 3px;
}

QSplitter::handle:vertical {
    height: 3px;
}

QSplitter::handle:hover {
    background-color: #3B82F6;
}

/* ===== STATUS BAR ===== */
QStatusBar {
    background-color: #FFFFFF;
    border-top: 1px solid #E2E6EE;
    color: #5F6980;
    font-size: 9pt;
}

QStatusBar QLabel {
    color: #5F6980;
    padding: 2px 8px;
}

/* ===== MENU BAR ===== */
QMenuBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E6EE;
    padding: 2px 0px;
}

QMenuBar::item {
    padding: 6px 12px;
    border-radius: 4px;
    color: #1A1D23;
}

QMenuBar::item:selected {
    background-color: #F0F4FF;
    color: #3B82F6;
}

QMenuBar::item:pressed {
    background-color: #E0E7FF;
}

/* ===== MENUS (Dropdown) ===== */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #E2E6EE;
    border-radius: 8px;
    padding: 6px 0px;
}

QMenu::item {
    padding: 6px 24px 6px 16px;
    border-radius: 4px;
    margin: 1px 4px;
}

QMenu::item:selected {
    background-color: #F0F4FF;
    color: #3B82F6;
}

QMenu::separator {
    height: 1px;
    background-color: #E2E6EE;
    margin: 4px 12px;
}

QMenu::icon {
    left: 6px;
}

/* ===== LABELS ===== */
QLabel {
    color: #1A1D23;
}

QLabel#TitleLabel {
    color: #3B82F6;
    font-size: 14pt;
    font-weight: 700;
}

QLabel#SubtitleLabel {
    color: #5F6980;
    font-size: 9pt;
}

QLabel#KpiLabel {
    font-weight: 600;
    font-size: 11pt;
}

QLabel#NotificationLabel {
    font-weight: 500;
    padding: 8px 12px;
}

/* ===== TOOLTIP ===== */
QToolTip {
    background-color: #1A1D23;
    color: #FFFFFF;
    border: 1px solid #374151;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 9pt;
}

/* ===== DIALOG ===== */
QDialog {
    background-color: #F5F7FA;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}

/* ===== QMessageBox ===== */
QMessageBox QLabel {
    color: #1A1D23;
}

QMessageBox QPushButton {
    min-width: 80px;
}

/* ===== LOADING / SPLASH ===== */
#LoadingWidget {
    background-color: #F5F7FA;
}

#LoadingLabel {
    color: #5F6980;
    font-size: 12pt;
}

/* ===== SPECIAL: Notification states ===== */
#NotificationBar.success {
    background-color: #ECFDF5;
    border: 1px solid #A7F3D0;
}

#NotificationBar.success QLabel {
    color: #065F46;
}

#NotificationBar.warning {
    background-color: #FFFBEB;
    border: 1px solid #FDE68A;
}

#NotificationBar.warning QLabel {
    color: #92400E;
}

#NotificationBar.error {
    background-color: #FEF2F2;
    border: 1px solid #FECACA;
}

#NotificationBar.error QLabel {
    color: #991B1B;
}

#NotificationBar.info {
    background-color: #EFF6FF;
    border: 1px solid #BFDBFE;
}

#NotificationBar.info QLabel {
    color: #1E40AF;
}

/* ===== PYQTGRAPH containers ===== */
QGraphicsView {
    border: 2px solid #CBD5E1;
    border-radius: 6px;
    background-color: #FFFFFF;
}

/* ===== ScrollArea ===== */
QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

/* ===== ToolButton ===== */
QToolButton {
    border: 1px solid #D1D5DE;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: #FFFFFF;
    color: #1A1D23;
}

QToolButton:hover {
    background-color: #F7F9FC;
    border-color: #3B82F6;
}

QToolButton:pressed {
    background-color: #EEF1F6;
}
