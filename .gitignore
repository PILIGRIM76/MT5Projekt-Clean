configs/settings.json
configs/*.local.json
.env
.env.local
.env.*.local
*.secret
*.key

# --- Временные файлы ---
*.tmp
*.bak
*.old
*.orig
~$*.doc*
~$*.xls*
Thumbs.db
desktop.ini

# --- Сборка ---
