{
  "dashboard": {
    "id": null,
    "title": "MT5Projekt-Clean Overview",
    "tags": ["trading", "mt5", "ai"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Pipeline Latency (ms)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pipeline_latency_ms_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(pipeline_latency_ms_bucket[5m]))",
            "legendFormat": "p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Orders Executed vs Failed",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(orders_executed_total[5m])",
            "legendFormat": "Executed"
          },
          {
            "expr": "rate(orders_failed_total[5m])",
            "legendFormat": "Failed"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Component Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "component_health_status",
            "legendFormat": "{{component}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "Critical"}}, "type": "value"},
              {"options": {"1": {"text": "Degraded"}}, "type": "value"},
              {"options": {"2": {"text": "Healthy"}}, "type": "value"}
            ],
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 2}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Live Logs",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"mt5projekt_logs\"} |= \"ERROR\" or |= \"CRITICAL\"",
            "refId": "A"
          }
        ],
        "options": {
          "showLabels": true,
          "showTime": true,
          "wrapLogMessage": true
        },
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
