# ============================================================
# Genesis Trading System - Environment Variables
# ============================================================
# Скопируйте этот файл в .env и заполните вашими данными
# ============================================================

# ============================================================
# MetaTrader 5 Credentials
# ============================================================
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=MetaQuotes-Demo
MT5_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe

# ============================================================
# Database Configuration
# ============================================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=secure_password_change_me

# TimescaleDB
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5433
TIMESCALEDB_DB=trading_ts
TIMESCALEDB_USER=trading_user
TIMESCALEDB_PASSWORD=secure_password_change_me

# QuestDB
QUESTDB_HOST=localhost
QUESTDB_PORT=9000
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest_admin

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SQLite
SQLITE_PATH=database/trading_system.db

# ============================================================
# API Keys (получите на соответствующих сервисах)
# ============================================================
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_news_api_key
FCS_API_KEY=your_fcs_api_key

# ============================================================
# Encryption & Security
# ============================================================
ENCRYPTION_KEY=your_encryption_key_here

# ============================================================
# Grafana
# ============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# ============================================================
# Application Settings
# ============================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ============================================================
# AI Model Configuration
# ============================================================
# Путь к директории с AI-моделями (абсолютный или относительный)
# Для Docker используйте: MODEL_DIR=/models
MODEL_DIR=
# Формат моделей: keras, pytorch, onnx
MODEL_FORMAT=keras
# Имя активной модели (без расширения файла)
ACTIVE_MODEL=lstm_v4
# Имя резервной модели для fallback при ошибке загрузки основной
BACKUP_MODEL=lstm_v3

# ============================================================
# Trading Settings
# ============================================================
BACKTESTER_INITIAL_BALANCE=10000.0
RISK_PER_TRADE=0.02
MAX_DRAWDOWN_PERCENT=0.10
